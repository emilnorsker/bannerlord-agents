<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>AIInfluence</AssemblyName>
    <GenerateAssemblyInfo>False</GenerateAssemblyInfo>
    <TargetFramework>net472</TargetFramework>
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>
  <PropertyGroup>
    <LangVersion>12.0</LangVersion>
    <AllowUnsafeBlocks>True</AllowUnsafeBlocks>
  </PropertyGroup>

  <!-- In CI, the workflow copies ref DLLs to .bl-refs/ before building.
       When that folder exists extend the assembly search path so bare
       <Reference> items can resolve from it. -->
  <PropertyGroup Condition="Exists('$(MSBuildProjectDirectory)/.bl-refs/')">
    <AssemblySearchPaths>$(AssemblySearchPaths);$(MSBuildProjectDirectory)/.bl-refs/</AssemblySearchPaths>
  </PropertyGroup>

  <ItemGroup>
    <PackageDownload Include="Bannerlord.ReferenceAssemblies.Core" Version="[1.3.15.110062]" />
    <PackageDownload Include="Bannerlord.ReferenceAssemblies.Native" Version="[1.3.15.110062]" />
    <PackageDownload Include="Bannerlord.ReferenceAssemblies.SandBox" Version="[1.3.15.110062]" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="TaleWorlds.CampaignSystem" />
    <Reference Include="TaleWorlds.SaveSystem" />
    <Reference Include="TaleWorlds.Localization" />
    <Reference Include="TaleWorlds.Core" />
    <Reference Include="TaleWorlds.Library" />
    <Reference Include="TaleWorlds.ObjectSystem" />
    <Reference Include="TaleWorlds.MountAndBlade" />
    <Reference Include="TaleWorlds.Engine.GauntletUI" />
    <Reference Include="TaleWorlds.GauntletUI" />
    <Reference Include="TaleWorlds.ScreenSystem" />
    <Reference Include="TaleWorlds.Engine" />
    <Reference Include="TaleWorlds.MountAndBlade.ViewModelCollection" />
    <Reference Include="TaleWorlds.MountAndBlade.View" />
    <Reference Include="TaleWorlds.MountAndBlade.GauntletUI.Widgets" />
    <Reference Include="TaleWorlds.CampaignSystem.ViewModelCollection" />
    <Reference Include="TaleWorlds.Core.ViewModelCollection" />
    <Reference Include="TaleWorlds.InputSystem" />
    <Reference Include="TaleWorlds.DotNet" />
    <Reference Include="SandBox" />
    <Reference Include="SandBox.View" />
    <Reference Include="SandBox.ViewModelCollection" />
    <Reference Include="OggVorbisEncoder">
      <HintPath>../bin/Win64_Shipping_Client/OggVorbisEncoder.dll</HintPath>
    </Reference>
    <Reference Include="System.Net.Http" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Lib.Harmony" Version="2.4.2" IncludeAssets="compile" PrivateAssets="all" />
    <PackageReference Include="Bannerlord.UIExtenderEx" Version="2.13.2" IncludeAssets="compile" PrivateAssets="all" />
    <PackageReference Include="Bannerlord.MCM" Version="5.11.3" IncludeAssets="compile" PrivateAssets="all" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" IncludeAssets="compile" PrivateAssets="all" />
  </ItemGroup>
</Project>
