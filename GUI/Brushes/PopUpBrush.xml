<Brushes>
  <Brush Name="Popup.Message.Text" Font="Galahad" TextHorizontalAlignment="Center">
    <Styles>
      <Style Name="Default" FontColor="#C6AC8DFF" TextGlowColor="#000000FF" TextOutlineColor="#000000FF" TextOutlineAmount="0.1" TextGlowRadius="0" TextBlur="0.6" FontSize="42" />
    </Styles>
  </Brush>

  <!-- "Conversation Log" header label — Figma: 12px +30% = 16 -->
  <Brush Name="Chat.Header.Label">
    <Styles>
      <Style Name="Default" FontColor="#FFE38FFF" FontSize="16" />
    </Styles>
  </Brush>

  <!-- NPC name in header — Figma spec: 15px +30% = 20 -->
  <Brush Name="Chat.Sender.Name">
    <Styles>
      <Style Name="Default" FontColor="#BBAE92FF" FontSize="20" />
    </Styles>
  </Brush>

  <!-- Message body text — Figma spec: 14px +30% = 18 -->
  <Brush Name="Chat.Body.Text">
    <Styles>
      <Style Name="Default" FontColor="#A1A1A1FF" FontSize="18" />
    </Styles>
  </Brush>

  <!-- Player action text — orange-red italic: 14px +30% = 18 -->
  <Brush Name="Chat.Action.Text">
    <Styles>
      <Style Name="Default" FontColor="#FF7451FF" FontSize="18" IsItalic="true" />
    </Styles>
  </Brush>

  <!-- Outcome text — warm gold: 14px +30% = 18 -->
  <!-- TODO: wire up in ContentSegmentVM outcome pill once IsOutcome segment type is added -->
  <Brush Name="Chat.Outcome.Text">
    <Styles>
      <Style Name="Default" FontColor="#E7C678FF" FontSize="18" />
    </Styles>
  </Brush>

  <!-- System event line — dimmed, centered: 12px +30% = 16 -->
  <!-- TODO: extend ChatInterface ContentSegments ItemTemplate if ContentSegmentVM gains IsEvent (not used yet; only IsBody/IsPill) -->
  <Brush Name="Chat.Event.Text">
    <Styles>
      <Style Name="Default" FontColor="#787880FF" FontSize="16" />
    </Styles>
  </Brush>

  <!-- Item grant notification text — purple: 13px +30% = 17 -->
  <!-- TODO: extend ChatInterface ContentSegments ItemTemplate if ContentSegmentVM gains IsItemGrant -->
  <Brush Name="Chat.ItemGrant.Text">
    <Styles>
      <Style Name="Default" FontColor="#E1ACEEEF" FontSize="17" />
    </Styles>
  </Brush>

  <!-- Clan → parties tab formation strips: states match OrderFormationClassVisualBrushWidget (Infantry/Ranged/Cavalry/HorseArcher). -->
  <Brush Name="AIInfluence.ClanPartyFormationStrip">
    <Styles>
      <Style Name="Infantry">
        <Layer Name="Default" Sprite="SPGeneral\Clan\party_troop_infantry_9" />
      </Style>
      <Style Name="Ranged">
        <Layer Name="Default" Sprite="SPGeneral\Clan\party_troop_ranged_9" />
      </Style>
      <Style Name="Cavalry">
        <Layer Name="Default" Sprite="SPGeneral\Clan\party_troop_cavalry_9" />
      </Style>
      <Style Name="HorseArcher">
        <Layer Name="Default" Sprite="SPGeneral\Clan\party_troop_horse_archer_9" />
      </Style>
    </Styles>
  </Brush>
</Brushes>