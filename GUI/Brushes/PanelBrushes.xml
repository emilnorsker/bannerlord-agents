<Brushes>

  <!-- ══════════════════════════════════════════════════
       Outer window frame — wraps center+right columns
       Uses native Encyclopedia.Frame layered with a
       darker inner fill to hit the Crownfall dark tone.
  ══════════════════════════════════════════════════ -->
  <Brush Name="Crownfall.Frame" TransitionDuration="0.05">
    <Layers>
      <BrushLayer Name="Fill"
                  Sprite="StdAssets\Popup\canvas"
                  Color="#100C07FF"
                  AlphaFactor="0.97"
                  ExtendLeft="6" ExtendRight="6" ExtendTop="6" ExtendBottom="6" />
      <BrushLayer Name="Border"
                  Sprite="frame_9"
                  Color="#C8A040FF"
                  AlphaFactor="0.38"
                  ExtendLeft="6" ExtendRight="6" ExtendTop="6" ExtendBottom="6" />
    </Layers>
    <Styles>
      <Style Name="Default" />
    </Styles>
  </Brush>

  <!-- ══════════════════════════════════════════════════
       Header bar — top strip showing NPC name + title
       "Talking with [Name]" / subtitle
  ══════════════════════════════════════════════════ -->
  <Brush Name="Crownfall.Header.Background" TransitionDuration="0.05">
    <Layers>
      <BrushLayer Name="Fill"
                  Sprite="StdAssets\Popup\canvas_gradient"
                  Color="#1A1208FF"
                  AlphaFactor="0.95"
                  ExtendLeft="6" ExtendRight="6" ExtendTop="0" ExtendBottom="0" />
      <BrushLayer Name="BottomRule"
                  Sprite="BlankWhiteSquare_9"
                  Color="#C8A040FF"
                  AlphaFactor="0.30"
                  OverridenHeight="1"
                  HeightPolicy="StretchToParent"
                  YOffset="1" />
    </Layers>
    <Styles>
      <Style Name="Default" />
    </Styles>
  </Brush>

  <!-- "Talking with " prefix text -->
  <Brush Name="Crownfall.Header.TitlePrefix" Font="Galahad" FontSize="30">
    <Styles>
      <Style Name="Default" FontColor="#EDE0C8FF" FontSize="30"
             TextGlowColor="#00000000" TextOutlineColor="#00000066"
             TextOutlineAmount="0.05" />
    </Styles>
  </Brush>

  <!-- NPC name in header (gold, larger) -->
  <Brush Name="Crownfall.Header.NpcName" Font="Galahad" FontSize="30">
    <Styles>
      <Style Name="Default" FontColor="#F0C060FF" FontSize="30"
             TextGlowColor="#D4A84344" TextGlowRadius="2"
             TextOutlineColor="#00000066" TextOutlineAmount="0.06" />
    </Styles>
  </Brush>

  <!-- Subtitle below title -->
  <Brush Name="Crownfall.Header.Subtitle" Font="Galahad" FontSize="16">
    <Styles>
      <Style Name="Default" FontColor="#A09080FF" FontSize="16" />
    </Styles>
  </Brush>

  <!-- ══════════════════════════════════════════════════
       Chat scroll area background
  ══════════════════════════════════════════════════ -->
  <Brush Name="Crownfall.Chat.Background" TransitionDuration="0.05">
    <Layers>
      <BrushLayer Name="Fill"
                  Sprite="StdAssets\Popup\canvas"
                  Color="#151009FF"
                  AlphaFactor="0.92"
                  ExtendLeft="4" ExtendRight="4" ExtendTop="4" ExtendBottom="4" />
    </Layers>
    <Styles>
      <Style Name="Default" />
    </Styles>
  </Brush>

  <!-- ══════════════════════════════════════════════════
       Input bar strip at bottom
  ══════════════════════════════════════════════════ -->
  <Brush Name="Crownfall.InputBar.Background" TransitionDuration="0.05">
    <Layers>
      <BrushLayer Name="Fill"
                  Sprite="StdAssets\Popup\canvas"
                  Color="#100C07FF"
                  AlphaFactor="0.97"
                  ExtendLeft="0" ExtendRight="0" ExtendTop="0" ExtendBottom="0" />
      <BrushLayer Name="TopRule"
                  Sprite="BlankWhiteSquare_9"
                  Color="#C8A040FF"
                  AlphaFactor="0.28"
                  OverridenHeight="1" />
    </Layers>
    <Styles>
      <Style Name="Default" />
    </Styles>
  </Brush>

  <!-- ══════════════════════════════════════════════════
       Right info panel background
  ══════════════════════════════════════════════════ -->
  <Brush Name="Crownfall.RightPanel.Background" TransitionDuration="0.05">
    <Layers>
      <BrushLayer Name="Fill"
                  Sprite="StdAssets\Popup\canvas"
                  Color="#1A1208FF"
                  AlphaFactor="0.90"
                  ExtendLeft="4" ExtendRight="4" ExtendTop="4" ExtendBottom="4" />
      <BrushLayer Name="LeftRule"
                  Sprite="BlankWhiteSquare_9"
                  Color="#C8A040FF"
                  AlphaFactor="0.22" />
    </Layers>
    <Styles>
      <Style Name="Default" />
    </Styles>
  </Brush>

  <!-- Section header text — "Character", "Recent World Events" -->
  <Brush Name="Crownfall.RightPanel.SectionHeader" Font="Galahad" FontSize="17">
    <Styles>
      <Style Name="Default" FontColor="#EDE0C8FF" FontSize="17"
             TextGlowColor="#00000000" TextOutlineColor="#00000055"
             TextOutlineAmount="0.05" />
    </Styles>
  </Brush>

  <!-- Stat label (e.g. "Gold on hand", "Times met") -->
  <Brush Name="Crownfall.RightPanel.StatLabel" Font="Galahad" FontSize="14">
    <Styles>
      <Style Name="Default" FontColor="#A09080FF" FontSize="14" />
    </Styles>
  </Brush>

  <!-- Stat value (e.g. "8,750", "2") -->
  <Brush Name="Crownfall.RightPanel.StatValue" Font="Galahad" FontSize="16">
    <Styles>
      <Style Name="Default" FontColor="#EDE0C8FF" FontSize="16" />
    </Styles>
  </Brush>

  <!-- Gold-coloured value (e.g. "Cautious", relation label) -->
  <Brush Name="Crownfall.RightPanel.GoldValue" Font="Galahad" FontSize="15">
    <Styles>
      <Style Name="Default" FontColor="#D4A843FF" FontSize="15" />
    </Styles>
  </Brush>

  <!-- Relation bar — filled (green/teal portion) -->
  <Brush Name="Crownfall.Relation.BarFill" TransitionDuration="0.15">
    <Layers>
      <BrushLayer Name="Fill"
                  Sprite="BlankWhiteSquare_9"
                  Color="#4A8A4AFF"
                  AlphaFactor="0.80"
                  ExtendLeft="2" ExtendRight="2" ExtendTop="2" ExtendBottom="2" />
    </Layers>
    <Styles>
      <Style Name="Default" />
    </Styles>
  </Brush>

  <!-- Relation bar — empty track -->
  <Brush Name="Crownfall.Relation.BarTrack" TransitionDuration="0.05">
    <Layers>
      <BrushLayer Name="Track"
                  Sprite="BlankWhiteSquare_9"
                  Color="#3A2E22FF"
                  AlphaFactor="0.85"
                  ExtendLeft="2" ExtendRight="2" ExtendTop="2" ExtendBottom="2" />
    </Layers>
    <Styles>
      <Style Name="Default" />
    </Styles>
  </Brush>

  <!-- Relation extremity labels ("Cold", "Friendly") -->
  <Brush Name="Crownfall.Relation.RangeLabel" Font="Galahad" FontSize="12">
    <Styles>
      <Style Name="Default" FontColor="#8A7A6AFF" FontSize="12" />
    </Styles>
  </Brush>

  <!-- Relation numeric delta ("+12") -->
  <Brush Name="Crownfall.Relation.Delta" Font="Galahad" FontSize="13">
    <Styles>
      <Style Name="Default" FontColor="#D4A843FF" FontSize="13" />
    </Styles>
  </Brush>

  <!-- ══════════════════════════════════════════════════
       World event card row
  ══════════════════════════════════════════════════ -->
  <Brush Name="Crownfall.EventCard" TransitionDuration="0.08">
    <Layers>
      <BrushLayer Name="BG"
                  Sprite="name_shadow_9"
                  Color="#1E1509FF"
                  AlphaFactor="0.0"
                  ExtendLeft="8" ExtendRight="8" ExtendTop="6" ExtendBottom="6" />
    </Layers>
    <Styles>
      <Style Name="Default" />
      <Style Name="Hovered">
        <StyleLayers>
          <StyleLayer Name="BG" AlphaFactor="0.65" />
        </StyleLayers>
      </Style>
    </Styles>
  </Brush>

  <!-- Event title text -->
  <Brush Name="Crownfall.EventCard.Title" Font="Galahad" FontSize="14">
    <Styles>
      <Style Name="Default" FontColor="#EDE0C8FF" FontSize="14" />
    </Styles>
  </Brush>

  <!-- Event sub-line (location · time) -->
  <Brush Name="Crownfall.EventCard.SubLine" Font="Galahad" FontSize="12">
    <Styles>
      <Style Name="Default" FontColor="#8A7A6AFF" FontSize="12" />
    </Styles>
  </Brush>

  <!-- ══════════════════════════════════════════════════
       Gold horizontal separator (used between sections)
  ══════════════════════════════════════════════════ -->
  <Brush Name="Crownfall.Separator" TransitionDuration="0.05">
    <Layers>
      <BrushLayer Name="Line"
                  Sprite="BlankWhiteSquare_9"
                  Color="#C8A040FF"
                  AlphaFactor="0.28" />
    </Layers>
    <Styles>
      <Style Name="Default" />
    </Styles>
  </Brush>

  <!-- Close button -->
  <Brush Name="Crownfall.CloseButton" TransitionDuration="0.1">
    <Layers>
      <BrushLayer Name="BG"
                  Sprite="name_shadow_9"
                  Color="#1A1208FF"
                  AlphaFactor="0.0"
                  ExtendLeft="8" ExtendRight="8" ExtendTop="6" ExtendBottom="6" />
    </Layers>
    <Styles>
      <Style Name="Default" FontColor="#8A7A6AFF" FontSize="18" />
      <Style Name="Hovered" FontColor="#F0C060FF" FontSize="18">
        <StyleLayers>
          <StyleLayer Name="BG" AlphaFactor="0.55" />
        </StyleLayers>
      </Style>
      <Style Name="Pressed" FontColor="#D4A843FF" FontSize="18">
        <StyleLayers>
          <StyleLayer Name="BG" AlphaFactor="0.80" />
        </StyleLayers>
      </Style>
    </Styles>
  </Brush>

  <!-- Left-panel stat overlay (relation / trust / emotion labels over portrait) -->
  <Brush Name="Crownfall.Portrait.StatOverlay" TransitionDuration="0.05">
    <Layers>
      <BrushLayer Name="BG"
                  Sprite="StdAssets\Popup\canvas_gradient"
                  Color="#0A0600FF"
                  AlphaFactor="0.60"
                  ExtendLeft="0" ExtendRight="0" ExtendTop="0" ExtendBottom="0" />
    </Layers>
    <Styles>
      <Style Name="Default" />
    </Styles>
  </Brush>

  <Brush Name="Crownfall.Portrait.StatText" Font="Galahad" FontSize="14">
    <Styles>
      <Style Name="Default" FontColor="#D4A843FF" FontSize="14" />
    </Styles>
  </Brush>

</Brushes>
