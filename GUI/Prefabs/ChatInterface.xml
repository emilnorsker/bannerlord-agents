<Prefab>
  <!--
    Crownfall layout — three columns, full screen:
      Left  (0..Left.W)   : transparent — 3D portrait shows through.
                            Stat overlay at very bottom of portrait area.
      Sep   (Left.W)      : 2px gold separator
      Frame (Left.W+2..end): Crownfall dark frame
        Header (Header.H) : "Talking with [NpcName]" / subtitle + close button
        Center (stretch)  : chat scroll + input bar
        Right  (Right.W)  : character stats + world events
  -->
  <Constants>
    <Constant Name="Header.H"    Value="80" />
    <Constant Name="Left.W"      Value="460" />
    <Constant Name="Right.W"     Value="220" />
    <Constant Name="Sep.W"       Value="2" />
    <Constant Name="Input.H"     Value="65" />
    <Constant Name="Bubble.W"    Value="420" />
    <Constant Name="Frame.Start" Value="462" />
  </Constants>

  <Window Id="ChatInterfaceWindow" Layer="Overlay">

    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
            DoNotAcceptEvents="false">
      <Children>

        <!-- ══ LEFT — transparent portrait area ══ -->
        <Widget HorizontalAlignment="Left"
                WidthSizePolicy="Fixed" SuggestedWidth="!Left.W"
                HeightSizePolicy="StretchToParent">
          <Children>
            <!-- Stat overlay at bottom of portrait: relation / trust / emotion -->
            <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                         SuggestedHeight="52"
                         VerticalAlignment="Bottom"
                         Brush="Crownfall.Portrait.StatOverlay">
              <Children>
                <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                               HorizontalAlignment="Left" VerticalAlignment="Top"
                               PositionXOffset="10" PositionYOffset="8"
                               Brush="Crownfall.Portrait.StatText"
                               Brush.FontSize="14" Color="@RelationColor"
                               Text="@RelationText" IsDisabled="true" />
                <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                               HorizontalAlignment="Right" VerticalAlignment="Top"
                               PositionXOffset="-10" PositionYOffset="8"
                               Brush="Crownfall.Portrait.StatText"
                               Text="@TrustLabel" IsDisabled="true" />
                <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                               HorizontalAlignment="Left" VerticalAlignment="Bottom"
                               PositionXOffset="10" PositionYOffset="-8"
                               Brush="Crownfall.Portrait.StatText"
                               Text="@EmotionLabel" IsDisabled="true" />
              </Children>
            </BrushWidget>
          </Children>
        </Widget>

        <!-- Vertical separator between portrait and frame -->
        <Widget HorizontalAlignment="Left"
                WidthSizePolicy="Fixed" SuggestedWidth="!Sep.W"
                HeightSizePolicy="StretchToParent"
                PositionXOffset="!Left.W"
                Brush="Crownfall.Separator" />

        <!-- ══ FRAME — dark panel covering center + right ══ -->
        <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                     MarginLeft="!Frame.Start"
                     Brush="Crownfall.Frame">
          <Children>

            <!-- ── HEADER — "Talking with [Name]" / subtitle + close ── -->
            <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                         SuggestedHeight="!Header.H"
                         VerticalAlignment="Top"
                         Brush="Crownfall.Header.Background">
              <Children>

                <!-- Title row: "Talking with " + NpcName, centred -->
                <ListPanel WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                           HorizontalAlignment="Center" VerticalAlignment="Top"
                           PositionYOffset="12"
                           StackLayout.LayoutMethod="HorizontalLeftToRight">
                  <Children>
                    <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                Brush="Crownfall.Header.TitlePrefix"
                                Text="Talking with " IsDisabled="true" />
                    <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                   Brush="Crownfall.Header.NpcName"
                                   Text="@NpcName" IsDisabled="true" />
                  </Children>
                </ListPanel>

                <!-- Subtitle: NPC title / role -->
                <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                               HorizontalAlignment="Center" VerticalAlignment="Bottom"
                               PositionYOffset="-10"
                               Brush="Crownfall.Header.Subtitle"
                               Text="@NpcTitle" IsDisabled="true" />

                <!-- Close button — top right -->
                <ButtonWidget WidthSizePolicy="Fixed" SuggestedWidth="36"
                              HeightSizePolicy="Fixed" SuggestedHeight="36"
                              HorizontalAlignment="Right" VerticalAlignment="Top"
                              PositionXOffset="-8" PositionYOffset="8"
                              Brush="Crownfall.CloseButton"
                              UpdateChildrenStates="true"
                              DoNotPassEventsToChildren="true"
                              Command.Click="ExecuteReturn">
                  <Children>
                    <TextWidget Text="✕"
                                WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Brush="Crownfall.CloseButton" />
                  </Children>
                </ButtonWidget>

              </Children>
            </BrushWidget>

            <!-- ── BODY — below header, center + right side by side ── -->
            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                    MarginTop="!Header.H">
              <Children>

                <!-- ── CENTER COLUMN — chat messages + input ── -->
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                        MarginRight="!Right.W">
                  <Children>

                    <!-- Chat scroll background -->
                    <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                 MarginBottom="!Input.H"
                                 Brush="Crownfall.Chat.Background" />

                    <!-- Message scroll area -->
                    <ScrollablePanel Id="MsgScroll"
                                     WidthSizePolicy="StretchToParent"
                                     HeightSizePolicy="StretchToParent"
                                     MarginBottom="!Input.H" MarginRight="24"
                                     AutoHideScrollBars="true"
                                     ClipRect="MsgClip"
                                     InnerPanel="MsgClip\MsgList"
                                     VerticalScrollbar="..\MsgScrollbar\Scrollbar">
                      <Children>
                        <Widget Id="MsgClip"
                                WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                ClipContents="true">
                          <Children>
                            <ListPanel Id="MsgList"
                                       DataSource="{MessageList}"
                                       WidthSizePolicy="StretchToParent"
                                       HeightSizePolicy="CoverChildren"
                                       StackLayout.LayoutMethod="VerticalBottomToTop"
                                       Spacing="12"
                                       MarginLeft="16" MarginRight="16"
                                       MarginTop="8" MarginBottom="8">
                              <ItemTemplate>
                                <!--
                                  Each message: NPC messages left, player messages right.
                                  Each ContentSegment is either a body bubble (IsBody)
                                  or an action/emote pill (IsPill).
                                -->
                                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                        MarginTop="2" MarginBottom="2">
                                  <Children>

                                    <!-- NPC message group -->
                                    <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                               StackLayout.LayoutMethod="VerticalBottomToTop"
                                               MarginLeft="8" MarginRight="140"
                                               IsVisible="@IsNpc">
                                      <Children>
                                        <!-- Name badge row -->
                                        <Widget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                MarginBottom="3">
                                          <Children>
                                            <BrushWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                         Brush="Crownfall.Chat.NameBadge">
                                              <Children>
                                                <ListPanel WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                           StackLayout.LayoutMethod="HorizontalLeftToRight"
                                                           MarginLeft="10" MarginRight="10"
                                                           MarginTop="5" MarginBottom="5">
                                                  <Children>
                                                    <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                                   Brush="Crownfall.Text.NpcName"
                                                                   Text="@SenderName" IsDisabled="true" />
                                                    <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                                VerticalAlignment="Bottom"
                                                                MarginLeft="8" MarginBottom="2"
                                                                Brush="Crownfall.Text.TypeTag"
                                                                Brush.FontColor="@TypeTagColor"
                                                                Text="@TypeTag" />
                                                  </Children>
                                                </ListPanel>
                                              </Children>
                                            </BrushWidget>
                                          </Children>
                                        </Widget>

                                        <!-- Content segments (bubbles / pills) -->
                                        <ListPanel DataSource="{ContentSegments}"
                                                   WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                   StackLayout.LayoutMethod="VerticalBottomToTop"
                                                   Spacing="6">
                                          <ItemTemplate>
                                            <!-- Body bubble -->
                                            <BrushWidget WidthSizePolicy="Fixed" SuggestedWidth="!Bubble.W"
                                                         HeightSizePolicy="CoverChildren"
                                                         HorizontalAlignment="Left"
                                                         IsVisible="@IsBody"
                                                         MarginTop="2" MarginBottom="2"
                                                         Brush="Crownfall.Chat.Bubble.Npc">
                                              <Children>
                                                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                            Margin="14,8,14,8"
                                                            Brush="Crownfall.Text.Body"
                                                            Brush.FontColor="@TextColor"
                                                            Text="@Text" />
                                              </Children>
                                            </BrushWidget>
                                            <!-- Action/emote pill -->
                                            <BrushWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                         HorizontalAlignment="Left"
                                                         IsVisible="@IsPill"
                                                         MarginTop="2" MarginBottom="2"
                                                         Brush="Crownfall.Chat.Bubble.Memory">
                                              <Children>
                                                <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                            Margin="14,5,14,5"
                                                            Brush="Crownfall.Text.Body"
                                                            Brush.FontColor="@TextColor"
                                                            Text="@Text" />
                                              </Children>
                                            </BrushWidget>
                                          </ItemTemplate>
                                        </ListPanel>
                                      </Children>
                                    </ListPanel>

                                    <!-- Player message group -->
                                    <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                               StackLayout.LayoutMethod="VerticalBottomToTop"
                                               MarginLeft="140" MarginRight="8"
                                               HorizontalAlignment="Right"
                                               IsVisible="@IsPlayer">
                                      <Children>
                                        <!-- "You" label -->
                                        <Widget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                HorizontalAlignment="Right" MarginBottom="3">
                                          <Children>
                                            <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                        MarginRight="4"
                                                        Brush="Crownfall.Text.YouLabel"
                                                        Text="You" IsDisabled="true" />
                                          </Children>
                                        </Widget>

                                        <!-- Content segments (right-aligned) -->
                                        <ListPanel DataSource="{ContentSegments}"
                                                   WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                   StackLayout.LayoutMethod="VerticalBottomToTop"
                                                   Spacing="6">
                                          <ItemTemplate>
                                            <BrushWidget WidthSizePolicy="Fixed" SuggestedWidth="!Bubble.W"
                                                         HeightSizePolicy="CoverChildren"
                                                         HorizontalAlignment="Right"
                                                         IsVisible="@IsBody"
                                                         MarginTop="2" MarginBottom="2"
                                                         Brush="Crownfall.Chat.Bubble.Player">
                                              <Children>
                                                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                            Margin="14,8,14,8"
                                                            Brush="Crownfall.Text.Body"
                                                            Brush.FontColor="@TextColor"
                                                            TextHorizontalAlignment="Right"
                                                            Text="@Text" />
                                              </Children>
                                            </BrushWidget>
                                            <BrushWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                         HorizontalAlignment="Right"
                                                         IsVisible="@IsPill"
                                                         MarginTop="2" MarginBottom="2"
                                                         Brush="Crownfall.Chat.Bubble.Memory">
                                              <Children>
                                                <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                            Margin="14,5,14,5"
                                                            Brush="Crownfall.Text.Body"
                                                            Brush.FontColor="@TextColor"
                                                            TextHorizontalAlignment="Right"
                                                            Text="@Text" />
                                              </Children>
                                            </BrushWidget>
                                          </ItemTemplate>
                                        </ListPanel>
                                      </Children>
                                    </ListPanel>

                                  </Children>
                                </Widget>
                              </ItemTemplate>
                            </ListPanel>
                          </Children>
                        </Widget>
                      </Children>
                    </ScrollablePanel>

                    <!-- Scrollbar -->
                    <Standard.VerticalScrollbar Id="MsgScrollbar"
                                                WidthSizePolicy="Fixed" SuggestedWidth="20"
                                                HeightSizePolicy="StretchToParent"
                                                HorizontalAlignment="Right"
                                                MarginBottom="!Input.H" MarginRight="2" />

                    <!-- ── INPUT BAR ── -->
                    <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                 SuggestedHeight="!Input.H"
                                 VerticalAlignment="Bottom"
                                 Brush="Crownfall.InputBar.Background">
                      <Children>

                        <!-- Input field -->
                        <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                     SuggestedHeight="42"
                                     HorizontalAlignment="Left" VerticalAlignment="Center"
                                     MarginLeft="10" MarginRight="60"
                                     Brush="Crownfall.Chat.InputField">
                          <Children>
                            <EditableTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Margin="14,6,14,6"
                                               Brush="Crownfall.Chat.InputText"
                                               Text="@InputText"
                                               Command.TextChanged="OnTextChanged" />
                          </Children>
                        </BrushWidget>

                        <!-- Send button -->
                        <ButtonWidget WidthSizePolicy="Fixed" SuggestedWidth="48"
                                      HeightSizePolicy="Fixed" SuggestedHeight="42"
                                      HorizontalAlignment="Right" VerticalAlignment="Center"
                                      MarginRight="8"
                                      IsEnabled="@IsSendEnabled"
                                      Brush="Crownfall.Chat.SendButton"
                                      UpdateChildrenStates="true"
                                      DoNotPassEventsToChildren="true"
                                      Command.Click="ExecuteSendMessage">
                          <Children>
                            <TextWidget Text="→"
                                        WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Brush="Crownfall.Chat.SendButton.Text"
                                        Brush.FontSize="22" />
                          </Children>
                        </ButtonWidget>

                      </Children>
                    </BrushWidget>

                  </Children>
                </Widget>

                <!-- Vertical separator between center and right panel -->
                <Widget HorizontalAlignment="Right"
                        WidthSizePolicy="Fixed" SuggestedWidth="!Sep.W"
                        HeightSizePolicy="StretchToParent"
                        PositionXOffset="-!Right.W"
                        Brush="Crownfall.Separator" />

                <!-- ── RIGHT COLUMN — character stats + events ── -->
                <BrushWidget HorizontalAlignment="Right"
                             WidthSizePolicy="Fixed" SuggestedWidth="!Right.W"
                             HeightSizePolicy="StretchToParent"
                             Brush="Crownfall.RightPanel.Background">
                  <Children>

                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                            MarginLeft="10" MarginRight="10" MarginTop="10" MarginBottom="10">
                      <Children>

                        <!-- "Character" section header -->
                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                    VerticalAlignment="Top"
                                    Brush="Crownfall.RightPanel.SectionHeader"
                                    Text="Character" IsDisabled="true" />

                        <!-- ── Relation + stats scrollable area ── -->
                        <ScrollablePanel Id="RightScroll"
                                         WidthSizePolicy="StretchToParent"
                                         HeightSizePolicy="StretchToParent"
                                         MarginTop="30" MarginRight="20"
                                         AutoHideScrollBars="true"
                                         ClipRect="RightClip"
                                         InnerPanel="RightClip\RightList"
                                         VerticalScrollbar="..\RightScrollbar\Scrollbar">
                          <Children>
                            <Widget Id="RightClip"
                                    WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                    ClipContents="true">
                              <Children>
                                <ListPanel Id="RightList"
                                           WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                           StackLayout.LayoutMethod="VerticalTopToBottom"
                                           Spacing="2">
                                  <Children>

                                    <!-- Gold separator -->
                                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                            SuggestedHeight="1" MarginTop="2" MarginBottom="6"
                                            Brush="Crownfall.Separator" />

                                    <!-- Relation section header -->
                                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                Brush="Crownfall.RightPanel.SectionHeader"
                                                Brush.FontSize="14"
                                                Text="Relation" IsDisabled="true" />

                                    <!-- Relation range labels: Cold … Friendly -->
                                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                            MarginTop="4">
                                      <Children>
                                        <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                    HorizontalAlignment="Left"
                                                    Brush="Crownfall.Relation.RangeLabel"
                                                    Text="Cold" IsDisabled="true" />
                                        <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                    HorizontalAlignment="Right"
                                                    Brush="Crownfall.Relation.RangeLabel"
                                                    Text="Friendly" IsDisabled="true" />
                                      </Children>
                                    </Widget>

                                    <!-- Relation bar track + fill -->
                                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                            SuggestedHeight="10"
                                            MarginTop="2" MarginBottom="2">
                                      <Children>
                                        <!-- track -->
                                        <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                                     Brush="Crownfall.Relation.BarTrack" />
                                        <!-- fill — width driven by @RelationFill (0..1) via PositionXOffset hack) -->
                                        <BrushWidget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                                                     SuggestedWidth="@RelationBarWidth"
                                                     Brush="Crownfall.Relation.BarFill" />
                                      </Children>
                                    </Widget>

                                    <!-- Relation delta + label -->
                                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                            MarginBottom="4">
                                      <Children>
                                        <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                       HorizontalAlignment="Center"
                                                       Brush="Crownfall.Relation.Delta"
                                                       Text="@RelationText" IsDisabled="true" />
                                      </Children>
                                    </Widget>

                                    <!-- Relation label ("Cautious" etc.) in gold -->
                                    <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                   HorizontalAlignment="Center"
                                                   MarginBottom="8"
                                                   Brush="Crownfall.RightPanel.GoldValue"
                                                   Text="@TrustLabel" IsDisabled="true" />

                                    <!-- Separator -->
                                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                            SuggestedHeight="1" MarginTop="2" MarginBottom="6"
                                            Brush="Crownfall.Separator" />

                                    <!-- Generic stat/info list (times met, known for, etc.) -->
                                    <ListPanel DataSource="{RightPanelItems}"
                                               WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                               StackLayout.LayoutMethod="VerticalTopToBottom"
                                               Spacing="4">
                                      <ItemTemplate>
                                        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                MarginTop="1" MarginBottom="1">
                                          <Children>
                                            <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                           Brush="Crownfall.RightPanel.StatLabel"
                                                           Brush.FontSize="13"
                                                           Brush.FontColor="@Color"
                                                           Text="@Text" IsDisabled="true" />
                                          </Children>
                                        </Widget>
                                      </ItemTemplate>
                                    </ListPanel>

                                    <!-- Separator before events -->
                                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                            SuggestedHeight="1" MarginTop="8" MarginBottom="6"
                                            Brush="Crownfall.Separator" />

                                    <!-- "Recent World Events" section header -->
                                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                MarginBottom="6"
                                                Brush="Crownfall.RightPanel.SectionHeader"
                                                Text="Recent World Events" IsDisabled="true" />

                                  </Children>
                                </ListPanel>
                              </Children>
                            </Widget>
                          </Children>
                        </ScrollablePanel>

                        <Standard.VerticalScrollbar Id="RightScrollbar"
                                                    WidthSizePolicy="Fixed" SuggestedWidth="18"
                                                    HeightSizePolicy="StretchToParent"
                                                    HorizontalAlignment="Right"
                                                    MarginTop="30" MarginRight="0" />

                      </Children>
                    </Widget>

                  </Children>
                </BrushWidget>

              </Children>
            </Widget>

          </Children>
        </BrushWidget>

      </Children>
    </Widget>
  </Window>
</Prefab>
