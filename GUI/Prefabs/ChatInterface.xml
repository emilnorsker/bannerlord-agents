<Prefab>
  <!--
    NPC chat = encyclopedia-first shell (SandBox EncyclopediaHeroPage.xml), not the old frame-first layout.
    Root: Encyclopedia.Page.SoundBrush. Row: vanilla hero left strip (370) | conversation column | information column.
    Bindings: NpcChatWindowVM — HeroCharacter, Traits, HeroSkillList, MessageList, InfoSections, etc.
  -->
  <Constants>
    <Constant Name="EncyLeft.W" Value="370" />
    <Constant Name="Info.W" Value="430" />
    <Constant Name="Sep.W" Value="2" />
    <Constant Name="Inset" Value="20" />
    <Constant Name="Header.H" Value="72" />
    <Constant Name="Input.H" Value="52" />
    <Constant Name="Msg.Margin" Value="30" />
    <Constant Name="Gold" Value="#FFE6B685" />
    <Constant Name="SepColor" Value="#FFFFFF22" />
  </Constants>

  <!-- Overlay layer root: hosts the whole chat UI. -->
  <Window Id="ChatInterfaceWindow" Layer="Overlay">
    <!-- Full-screen shell; encyclopedia page brush (ambient sound/visual parent for this screen). -->
    <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                 DoNotAcceptEvents="true" Brush="Encyclopedia.Page.SoundBrush">
      <Children>
        <!-- Content root with inset margin; receives input for the whole chat. -->
        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                MarginLeft="!Inset" MarginRight="!Inset" MarginTop="!Inset" MarginBottom="!Inset"
                DoNotAcceptEvents="false">
          <Children>
            <!-- Three columns: hero strip | chat | info panel. -->
            <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                       StackLayout.LayoutMethod="HorizontalLeftToRight" DoNotAcceptEvents="false">
              <Children>

                <!-- ══ Left: vanilla encyclopedia hero column (unchanged structure) ══ -->
                <!-- Left column background; gradient behind tableau and text blocks. -->
                <Widget HeightSizePolicy="StretchToParent" WidthSizePolicy="Fixed" SuggestedWidth="!EncyLeft.W"
                        Sprite="General\CharacterCreation\character_creation_background_gradient">
                  <Children>
                    <!-- Clips tableau stack; holds layered 3D portrait + decorative sprites. -->
                    <Widget WidthSizePolicy="Fixed" SuggestedWidth="!EncyLeft.W" HeightSizePolicy="StretchToParent"
                            HorizontalAlignment="Left" MarginBottom="1" VerticalAlignment="Center" IsEnabled="false" ClipContents="true">
                      <Children>
                        <!-- 3D hero portrait / equipment tableau from HeroCharacter VM. -->
                        <EncyclopediaCharacterTableauWidget DataSource="{HeroCharacter}" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                            BodyProperties="@BodyProperties" IsFemale="@IsFemale" EquipmentCode="@EquipmentCode" CharStringId="@CharStringId"
                            StanceIndex="@StanceIndex" BannerCodeText="@BannerCodeText" MountCreationKey="@MountCreationKey" IsEnabled="false"
                            IsDead="@IsDead" ArmorColor1="@ArmorColor1" ArmorColor2="@ArmorColor2" IdleAction="@IdleAction"
                            IdleFaceAnim="@IdleFaceAnim" Race="@Race" IsHidden="@IsHidden"/>
                        <!-- Silhouette when hero info is hidden. -->
                        <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="478" SuggestedHeight="666"
                                HorizontalAlignment="Center" VerticalAlignment="Bottom" ValueFactor="20"
                                Sprite="Encyclopedia\hero_silhouette" IsVisible="@IsInformationHidden"/>
                        <!-- Animated smoke drift behind the figure (vanilla encyclopedia effect). -->
                        <ParallaxItemBrushWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="582" SuggestedHeight="380"
                            Brush="Encyclopedia.Character.Smoke" OneDirectionDuration="5" OneDirectionDistance="100" InitialDirection="Right"
                            IsEaseInOutEnabled="true" VerticalAlignment="Bottom" HorizontalAlignment="Center" PositionYOffset="1"/>
                        <ParallaxItemBrushWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="582" SuggestedHeight="380"
                            Brush="Encyclopedia.Character.Smoke2" OneDirectionDuration="5" OneDirectionDistance="100" InitialDirection="Left"
                            IsEaseInOutEnabled="true" VerticalAlignment="Bottom" HorizontalAlignment="Center" PositionYOffset="1"/>
                      </Children>
                    </Widget>
                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                Brush="Encyclopedia.SubPage.Info.Text" Brush.FontColor="#F4E1C4FF" Brush.TextHorizontalAlignment="Center"
                                VerticalAlignment="Bottom" MarginBottom="25" IsVisible="@IsInformationHidden" Text="@InfoHiddenReasonText"/>
                    <!-- Name, title, traits row; stacks bottom-up for encyclopedia-style placement. -->
                    <ListPanel HeightSizePolicy="CoverChildren" WidthSizePolicy="StretchToParent"
                               StackLayout.LayoutMethod="VerticalBottomToTop" MarginLeft="20" MarginRight="20">
                      <Children>
                        <TextWidget DoNotAcceptEvents="true" WidthSizePolicy="Fixed" HeightSizePolicy="CoverChildren" SuggestedWidth="250" MaxHeight="150"
                                    Brush="Encyclopedia.SubPage.Title.Text" HorizontalAlignment="Center"
                                    Brush.TextHorizontalAlignment="Center" Brush.TextVerticalAlignment="Top" MarginTop="10" Text="@NpcName"/>
                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                    Brush="Encyclopedia.SubPage.Info.Text" Brush.FontColor="#E1BE8FFF" Brush.TextHorizontalAlignment="Center" Text="@NpcTitle"/>
                        <!-- Pregnant icon; hover hint from VM. -->
                        <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="34" SuggestedHeight="34" MarginTop="2"
                                HorizontalAlignment="Center" Sprite="SPGeneral\Clan\Status\icon_pregnant" IsVisible="@IsPregnant">
                          <Children>
                            <HintWidget DataSource="{PregnantHint}" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                        Command.HoverBegin="ExecuteBeginHint" Command.HoverEnd="ExecuteEndHint"/>
                          </Children>
                        </Widget>
                        <!-- Gamepad/keyboard: defines where focus enters the trait strip. -->
                        <NavigationScopeTargeter ScopeID="NpcChatHeroTraitsScope" ScopeParent="..\NpcChatTraits" ScopeMovements="Horizontal"
                            NavigateFromScopeEdges="true" UseDiscoveryAreaAsScopeEdges="true" ExtendDiscoveryAreaBottom="220"/>
                        <!-- Horizontal list of trait icons; navigatable for controller. -->
                        <NavigatableListPanel Id="NpcChatTraits" DataSource="{Traits}" WidthSizePolicy="CoverChildren" HeightSizePolicy="Fixed"
                                              SuggestedHeight="75" HorizontalAlignment="Center" MarginTop="2">
                          <ItemTemplate>
                            <EncyclopediaHeroTraitVisualWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="74" SuggestedHeight="75"
                                MarginLeft="-7" MarginRight="-7" TraitId="@TraitId" TraitValue="@Value"
                                ExtendCursorAreaLeft="-10" ExtendCursorAreaRight="-10" ExtendCursorAreaTop="-10" ExtendCursorAreaBottom="-10">
                              <Children>
                                <HintWidget DataSource="{Hint}" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                            Command.HoverBegin="ExecuteBeginHint" Command.HoverEnd="ExecuteEndHint"/>
                              </Children>
                            </EncyclopediaHeroTraitVisualWidget>
                          </ItemTemplate>
                        </NavigatableListPanel>
                      </Children>
                    </ListPanel>
                    <!-- Skills label + 6-column skill grid; pinned toward bottom of column. -->
                    <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Bottom" MarginLeft="10"
                               StackLayout.LayoutMethod="VerticalBottomToTop">
                      <Children>
                        <TextWidget HeightSizePolicy="CoverChildren" WidthSizePolicy="StretchToParent" Text="@SkillsText" HorizontalAlignment="Center"
                                    ClipContents="false" IsVisible="@HasAnySkills"/>
                        <NavigationScopeTargeter ScopeID="NpcChatHeroSkillsGridScope" ScopeParent="..\NpcChatSkillsGrid" ScopeMovements="Horizontal"
                            AlternateScopeMovements="Vertical" DownNavigationScope="None" AlternateMovementStepSize="6"
                            NavigateFromScopeEdges="true" UseDiscoveryAreaAsScopeEdges="true" ExtendDiscoveryAreaTop="220"/>
                        <NavigatableGridWidget Id="NpcChatSkillsGrid" DataSource="{HeroSkillList}" WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                            DefaultCellWidth="55" HorizontalAlignment="Center" MarginLeft="10" MarginRight="10" DefaultCellHeight="70" ColumnCount="6"
                            LayoutImp.VerticalLayoutMethod="TopToBottom">
                          <ItemTemplate>
                            <SkillIconVisualWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" SkillId="@SkillId"
                                                   MarginBottom="20" UseSmallestVariation="true" MarginLeft="3" MarginRight="3">
                              <Children>
                                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="20" IntText="@SkillValue"
                                            VerticalAlignment="Bottom" HorizontalAlignment="Center" Brush="Encyclopedia.Skill.Text"
                                            Brush.FontSize="20" PositionYOffset="20" ClipContents="false"/>
                                <HintWidget DataSource="{Hint}" HeightSizePolicy="StretchToParent" WidthSizePolicy="StretchToParent"
                                            Command.HoverBegin="ExecuteBeginHint" Command.HoverEnd="ExecuteEndHint"/>
                              </Children>
                            </SkillIconVisualWidget>
                          </ItemTemplate>
                        </NavigatableGridWidget>
                      </Children>
                    </ListPanel>
                    <!-- Vertical rule between left column and center chat. -->
                    <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="2" HorizontalAlignment="Right"
                            Sprite="Encyclopedia\divider_vertical"/>
                  </Children>
                </Widget>

                <!-- Thin separator between columns. -->
                <Widget WidthSizePolicy="Fixed" SuggestedWidth="!Sep.W" HeightSizePolicy="StretchToParent"
                        Sprite="BlankWhiteSquare_9" Color="!SepColor"/>

                <!-- ══ Center: conversation (replaces encyclopedia’s main scroll body) ══ -->
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent">
                  <Children>
                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                            Sprite="BlankWhiteSquare_9" Color="#141414FF" DoNotAcceptEvents="true"/>
                    <!-- Interactive layer: header, scroll, scrollbar, input bar. -->
                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" DoNotAcceptEvents="false">
                      <Children>
                        <!-- Top bar: conversation title + relation / trust / mood (text widgets inside). -->
                        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="!Header.H" VerticalAlignment="Top"
                                Sprite="BlankWhiteSquare_9" Color="#1A1A1AFF">
                          <Children>
                            <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                        HorizontalAlignment="Left" VerticalAlignment="Top" PositionXOffset="14" PositionYOffset="8"
                                        Brush="Chat.Header.Label" Text="Conversation" IsDisabled="true"/>
                            <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                            HorizontalAlignment="Left" VerticalAlignment="Bottom" PositionXOffset="14" PositionYOffset="-36"
                                            Brush="Encyclopedia.SubPage.Info.Text" Brush.FontSize="14" Color="@RelationColor"
                                            Text="@RelationText" IsDisabled="true"/>
                            <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom" PositionXOffset="-14" PositionYOffset="-36"
                                            Brush="Encyclopedia.SubPage.Info.Text" Brush.FontSize="14" Text="@TrustLabel" IsDisabled="true"/>
                            <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                        HorizontalAlignment="Left" VerticalAlignment="Bottom" PositionXOffset="14" PositionYOffset="-14"
                                        Brush="SPScoreboard.Subtitle.Text" Brush.FontSize="12" Text="@EmotionLabel" IsDisabled="true"/>
                          </Children>
                        </Widget>
                        <!-- Message list scroll; inner panel is MsgClip\MsgList; scrollbar is sibling MsgScrollbar. -->
                        <ScrollablePanel Id="MsgScroll" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                         MarginTop="!Header.H" MarginBottom="!Input.H" MarginRight="20" MarginLeft="4"
                                         AutoHideScrollBars="true" ClipRect="MsgClip" InnerPanel="MsgClip\MsgList"
                                         VerticalScrollbar="..\MsgScrollbar\Scrollbar">
                          <Children>
                            <Widget Id="MsgClip" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" ClipContents="true">
                              <Children>
                                <ListPanel Id="MsgList" DataSource="{MessageList}" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                           StackLayout.LayoutMethod="VerticalBottomToTop" Spacing="10" MarginLeft="14" MarginRight="14" MarginTop="6" MarginBottom="6">
                                  <ItemTemplate>
                                    <!-- One chat message row: NPC block and/or player block (visibility-bound). -->
                                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginTop="2" MarginBottom="1">
                                      <Children>
                                        <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left"
                                                   StackLayout.LayoutMethod="VerticalBottomToTop" MarginLeft="!Msg.Margin" MarginRight="!Msg.Margin" IsVisible="@IsNpc">
                                          <Children>
                                            <Widget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" Sprite="name_shadow_9" AlphaFactor="0.7">
                                              <Children>
                                                <ListPanel WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                           StackLayout.LayoutMethod="HorizontalLeftToRight" MarginLeft="10" MarginTop="4" MarginBottom="4">
                                                  <Children>
                                                    <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                                    Brush="Chat.Sender.Name" Text="@SenderName" IsDisabled="true"/>
                                                    <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                                VerticalAlignment="Bottom" MarginLeft="8" MarginBottom="3"
                                                                Brush="SPScoreboard.Subtitle.Text" Brush.FontSize="17" Brush.FontColor="@TypeTagColor" Text="@TypeTag"/>
                                                  </Children>
                                                </ListPanel>
                                              </Children>
                                            </Widget>
                                            <ListPanel DataSource="{ContentSegments}" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                       StackLayout.LayoutMethod="VerticalBottomToTop" Spacing="10">
                                              <ItemTemplate>
                                                <!-- Segment: body or pill (mutually exclusive via IsBody / IsPill). -->
                                                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren">
                                                  <Children>
                                                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" IsVisible="@IsBody" MarginTop="2" MarginBottom="2">
                                                      <Children>
                                                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" Margin="4,2,4,2"
                                                                    Brush="Chat.Body.Text" Brush.TextHorizontalAlignment="Left" Text="@Text"/>
                                                      </Children>
                                                    </Widget>
                                                    <Widget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" IsVisible="@IsPill" MarginTop="2" MarginBottom="2">
                                                      <Children>
                                                        <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" MaxWidth="540" Margin="4,2,4,2"
                                                                    Brush="Chat.Action.Text" Brush.FontColor="@TextColor" Brush.TextHorizontalAlignment="Left" Text="@Text"/>
                                                      </Children>
                                                    </Widget>
                                                  </Children>
                                                </Widget>
                                              </ItemTemplate>
                                            </ListPanel>
                                          </Children>
                                        </ListPanel>
                                        <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" StackLayout.LayoutMethod="VerticalBottomToTop"
                                                   MarginLeft="!Msg.Margin" MarginRight="!Msg.Margin" HorizontalAlignment="Right" IsVisible="@IsPlayer">
                                          <Children>
                                            <Widget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" HorizontalAlignment="Right">
                                              <Children>
                                                <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" HorizontalAlignment="Right"
                                                                MarginRight="10" MarginTop="4" MarginBottom="4" Brush="Chat.Sender.Name" Text="@SenderName" IsDisabled="true"/>
                                              </Children>
                                            </Widget>
                                            <ListPanel DataSource="{ContentSegments}" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                       StackLayout.LayoutMethod="VerticalBottomToTop" Spacing="10">
                                              <ItemTemplate>
                                                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren">
                                                  <Children>
                                                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" HorizontalAlignment="Right" IsVisible="@IsBody" MarginTop="2" MarginBottom="2">
                                                      <Children>
                                                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" Margin="4,2,4,2"
                                                                    Brush="Chat.Body.Text" Brush.TextHorizontalAlignment="Right" Text="@Text"/>
                                                      </Children>
                                                    </Widget>
                                                    <Widget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" HorizontalAlignment="Right" IsVisible="@IsPill" MarginTop="2" MarginBottom="2">
                                                      <Children>
                                                        <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" MaxWidth="540" Margin="4,2,4,2"
                                                                    Brush="Chat.Action.Text" Brush.FontColor="@TextColor" Brush.TextHorizontalAlignment="Right" Text="@Text"/>
                                                      </Children>
                                                    </Widget>
                                                  </Children>
                                                </Widget>
                                              </ItemTemplate>
                                            </ListPanel>
                                          </Children>
                                        </ListPanel>
                                      </Children>
                                    </Widget>
                                  </ItemTemplate>
                                </ListPanel>
                              </Children>
                            </Widget>
                          </Children>
                        </ScrollablePanel>
                        <!-- Vanilla vertical scrollbar; bound to MsgScroll. -->
                        <Standard.VerticalScrollbar Id="MsgScrollbar" WidthSizePolicy="Fixed" SuggestedWidth="22" HeightSizePolicy="StretchToParent"
                                                    HorizontalAlignment="Right" MarginTop="!Header.H" MarginBottom="!Input.H" MarginRight="2"/>
                        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="2" VerticalAlignment="Bottom"
                                PositionYOffset="-52" Sprite="BlankWhiteSquare_9" Color="!SepColor"/>
                        <!-- Bottom bar: decorative layers + text field + Send. -->
                        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="!Input.H" VerticalAlignment="Bottom"
                                Sprite="BlankWhiteSquare_9" Color="#1A110CFF">
                          <Children>
                            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                    Sprite="frame_9" ExtendLeft="4" ExtendTop="4" ExtendRight="4" ExtendBottom="4" AlphaFactor="0.34" IsEnabled="false"/>
                            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                    Sprite="General\CharacterCreation\character_creation_background_gradient" Color="#2A1A11FF" AlphaFactor="0.2" IsEnabled="false"/>
                            <!-- Input chrome (std popup text_input background) + inner frame. -->
                            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="38"
                                    HorizontalAlignment="Left" VerticalAlignment="Center" MarginLeft="8" MarginRight="106" Sprite="StdAssets\Popup\text_input">
                              <Children>
                                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                        Sprite="frame_9" ExtendLeft="3" ExtendTop="3" ExtendRight="3" ExtendBottom="3" AlphaFactor="0.16" IsEnabled="false"/>
                                <!-- Player message input; bound to VM, fires OnTextChanged. -->
                                <EditableTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,4,10,4"
                                                    Brush="Review.NameInput.Text" Text="@InputText" Command.TextChanged="OnTextChanged"/>
                              </Children>
                            </Widget>
                            <ButtonWidget WidthSizePolicy="Fixed" SuggestedWidth="90" HeightSizePolicy="Fixed" SuggestedHeight="38"
                                          HorizontalAlignment="Right" VerticalAlignment="Center" MarginRight="8" IsEnabled="@IsSendEnabled"
                                          Brush="Popup.Done.Button" UpdateChildrenStates="true" DoNotPassEventsToChildren="true" Command.Click="ExecuteSendMessage">
                              <Children>
                                <TextWidget Text="Send" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="22"
                                            VerticalAlignment="Center" MarginLeft="20" MarginRight="20" Brush="Popup.Button.Text"/>
                              </Children>
                            </ButtonWidget>
                          </Children>
                        </Widget>
                      </Children>
                    </Widget>
                  </Children>
                </Widget>

                <Widget WidthSizePolicy="Fixed" SuggestedWidth="!Sep.W" HeightSizePolicy="StretchToParent"
                        Sprite="BlankWhiteSquare_9" Color="!SepColor"/>

                <!-- ══ Right: information panel (encyclopedia-style scroll + shadow) ══ -->
                <Widget WidthSizePolicy="Fixed" SuggestedWidth="!Info.W" HeightSizePolicy="StretchToParent">
                  <Children>
                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                            Sprite="BlankWhiteSquare_9" Color="#141414FF" DoNotAcceptEvents="true"/>
                    <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="36" VerticalAlignment="Top"
                                    HorizontalAlignment="Center" PositionYOffset="8" Brush="SPScoreboard.Subtitle.Text"
                                    Brush.FontSize="23" Color="!Gold" Text="Information" IsDisabled="true"/>
                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="2" VerticalAlignment="Top"
                            PositionYOffset="48" MarginLeft="8" MarginRight="8" Sprite="BlankWhiteSquare_9" Color="!SepColor"/>
                    <!-- Encyclopedia frame border around the scroll area. -->
                    <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                 MarginTop="54" MarginBottom="50" MarginLeft="4" MarginRight="4"
                                 Brush="Encyclopedia.Frame" DoNotAcceptEvents="true">
                      <Children>
                        <ScrollablePanel Id="InfoScroll" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                         MarginTop="4" MarginBottom="4" MarginLeft="8" MarginRight="8"
                                         ClipRect="InfoRect" InnerPanel="InfoRect\InfoList"
                                         MouseScrollAxis="Vertical" VerticalScrollbar="..\..\InfoScrollbar" AutoHideScrollBars="true">
                          <Children>
                        <Widget Id="InfoRect" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" DoNotAcceptEvents="true" ClipContents="true">
                          <Children>
                            <NavigatableListPanel Id="InfoList" DataSource="{InfoSections}" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                  StackLayout.LayoutMethod="VerticalBottomToTop" Spacing="8" MarginLeft="4" MarginRight="4" MarginTop="4" MarginBottom="4">
                              <ItemTemplate>
                                <!-- One collapsible section: banner row + expanded body. -->
                                <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                           StackLayout.LayoutMethod="VerticalTopToBottom" Spacing="0" MarginLeft="2" MarginRight="2" MarginBottom="6">
                                  <Children>
                                    <ButtonWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="36"
                                                  Brush="Encyclopedia.TopBanner" Color="#0F141FFF" Command.Click="ExecuteToggle"
                                                  DoNotPassEventsToChildren="false" UpdateChildrenStates="true">
                                      <Children>
                                        <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                                   StackLayout.LayoutMethod="HorizontalLeftToRight" MarginLeft="10" MarginRight="10">
                                          <Children>
                                            <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                            Brush="Encyclopedia.SubPage.Title.Text" Brush.FontSize="16" Brush.TextHorizontalAlignment="Left"
                                                            VerticalAlignment="Center" Text="@HeaderText" IsDisabled="true"/>
                                            <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                                        Brush="Encyclopedia.SubPage.Info.Text" Brush.FontSize="16" Text="@ExpandGlyph"/>
                                          </Children>
                                        </ListPanel>
                                      </Children>
                                    </ButtonWidget>
                                    <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" IsVisible="@IsExpanded"
                                               StackLayout.LayoutMethod="VerticalTopToBottom" Spacing="4" MarginLeft="0" MarginRight="0" MarginTop="0" MarginBottom="2">
                                      <Children>
                                        <ListPanel DataSource="{WorldEventLines}" IsVisible="@HasWorldEventLines" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                   StackLayout.LayoutMethod="VerticalTopToBottom" Spacing="6" MarginLeft="4" MarginRight="4" MarginTop="4" MarginBottom="2">
                                          <ItemTemplate>
                                            <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                       StackLayout.LayoutMethod="HorizontalLeftToRight" MarginLeft="2" MarginRight="2">
                                              <Children>
                                                <SkillIconVisualWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="40" SuggestedHeight="40"
                                                                       VerticalAlignment="Top" HorizontalAlignment="Left" MarginRight="6" MarginTop="2"
                                                                       SkillId="@SkillId" UseSmallestVariation="true"/>
                                                <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center"
                                                                Brush="Encyclopedia.SubPage.Info.Text" Brush.FontSize="15" Brush.TextHorizontalAlignment="Left"
                                                                Color="@Color" Text="@Text" IsDisabled="true"/>
                                              </Children>
                                            </ListPanel>
                                          </ItemTemplate>
                                        </ListPanel>
                                        <ListPanel DataSource="{TextLines}" IsVisible="@HasStandardTextLines" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                   StackLayout.LayoutMethod="VerticalTopToBottom" Spacing="3" MarginLeft="8" MarginRight="4" MarginTop="4" MarginBottom="2">
                                          <ItemTemplate>
                                            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren">
                                              <Children>
                                                <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                                Brush="Encyclopedia.SubPage.Info.Text" Brush.FontSize="15" Color="@Color" Text="@Text" IsDisabled="true"/>
                                              </Children>
                                            </Widget>
                                          </ItemTemplate>
                                        </ListPanel>
                                        <ListPanel DataSource="{TroopRows}" IsVisible="@HasTroopRows" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                   StackLayout.LayoutMethod="VerticalTopToBottom" Spacing="4" MarginLeft="4" MarginRight="4" MarginTop="2" MarginBottom="4">
                                          <ItemTemplate>
                                            <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="40"
                                                       StackLayout.LayoutMethod="HorizontalLeftToRight" MarginLeft="4" MarginRight="4">
                                              <Children>
                                                <InventoryImageIdentifierWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="36" SuggestedHeight="36"
                                                                                VerticalAlignment="Center" HorizontalAlignment="Left" ImageIdentifier="@Portrait"/>
                                                <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center"
                                                                MarginLeft="8" Brush="Encyclopedia.SubPage.Info.Text" Brush.FontSize="15" Brush.TextHorizontalAlignment="Left"
                                                                Text="@FormationName" IsDisabled="true"/>
                                                <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" HorizontalAlignment="Right"
                                                            Brush="Encyclopedia.SubPage.Info.Text" Brush.FontSize="16" Text="@CountLabel"/>
                                              </Children>
                                            </ListPanel>
                                          </ItemTemplate>
                                        </ListPanel>
                                        <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" IsVisible="@ShowPartyFood"
                                                        MarginLeft="8" MarginBottom="4" Brush="Encyclopedia.SubPage.Info.Text" Brush.FontSize="15"
                                                        Color="@PartyFoodColor" Text="@PartyFoodText" IsDisabled="true"/>
                                      </Children>
                                    </ListPanel>
                                  </Children>
                                </ListPanel>
                              </ItemTemplate>
                            </NavigatableListPanel>
                            <!-- Bottom fade over scroll content (vanilla encyclopedia scroll shadow). -->
                            <BrushWidget DoNotAcceptEvents="true" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="120"
                                         VerticalAlignment="Bottom" HorizontalAlignment="Center" Brush="Encyclopedia.Scroll.Shadow" Brush.VerticalFlip="false"/>
                          </Children>
                        </Widget>
                          </Children>
                        </ScrollablePanel>
                      </Children>
                    </BrushWidget>
                    <!-- Custom flat scrollbar; VerticalScrollbar path on InfoScroll points here. -->
                    <ScrollbarWidget Id="InfoScrollbar" WidthSizePolicy="CoverChildren" HeightSizePolicy="StretchToParent"
                                     MarginRight="2" MarginBottom="54" MarginTop="54" AlignmentAxis="Vertical"
                                     HorizontalAlignment="Right" VerticalAlignment="Center" Handle="InfoScrollbarHandle" MinValue="0" MaxValue="100">
                      <Children>
                        <BrushWidget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="2" HorizontalAlignment="Center"
                                     Brush="Encyclopedia.Scrollbar.Flat.Bed"/>
                        <BrushWidget Id="InfoScrollbarHandle" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="8" SuggestedHeight="50"
                                     HorizontalAlignment="Center" Brush="Encyclopedia.Scrollbar.Flat.Handle"/>
                      </Children>
                    </ScrollbarWidget>
                    <ButtonWidget WidthSizePolicy="Fixed" SuggestedWidth="130" HeightSizePolicy="Fixed" SuggestedHeight="38"
                                  HorizontalAlignment="Center" VerticalAlignment="Bottom" MarginBottom="8"
                                  Brush="Popup.Cancel.Button" UpdateChildrenStates="true" DoNotPassEventsToChildren="true" Command.Click="ExecuteReturn">
                      <Children>
                        <TextWidget Text="Close" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="22"
                                    VerticalAlignment="Center" MarginLeft="30" MarginRight="25" Brush="Popup.Button.Text"/>
                      </Children>
                    </ButtonWidget>
                  </Children>
                </Widget>

              </Children>
            </ListPanel>
          </Children>
        </Widget>
      </Children>
    </BrushWidget>
  </Window>
