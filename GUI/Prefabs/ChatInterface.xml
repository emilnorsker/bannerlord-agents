<Prefab>
  <Constants>
    <Constant Name="Left.Width"   Value="280" />
    <Constant Name="Center.Width" Value="480" />
    <Constant Name="Right.Width"  Value="280" />
    <Constant Name="Win.Height"   Value="760" />
    <Constant Name="Gold"         Value="#FFE6B685" />
    <Constant Name="SubText"      Value="#AAAAAAFF" />
  </Constants>

  <Window Id="ChatInterfaceWindow" Layer="Overlay">

    <!-- Full-screen dark backdrop (same pattern as WorldEventsWindow) -->
    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
            DoNotAcceptEvents="false"
            Sprite="BlankWhiteSquare_9" Color="#0A0A0ACC">
      <Children>

        <!-- Centred fixed container holding the 3 columns -->
        <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                SuggestedWidth="1056" SuggestedHeight="!Win.Height"
                HorizontalAlignment="Center" VerticalAlignment="Center">
          <Children>

            <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                       StackLayout.LayoutMethod="Horizontal">
              <Children>

                <!-- ═══════════════════════════════════════════════════
                     LEFT  –  Portrait + stat overlay
                ════════════════════════════════════════════════════════ -->
                <BrushWidget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                             SuggestedWidth="!Left.Width"
                             Brush="Encyclopedia.Frame">
                  <Children>

                    <!-- Portrait fills the panel -->
                    <AIInfluencePortraitWidget
                        WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                        HorizontalAlignment="Center" VerticalAlignment="Center" />

                    <!-- TOP overlay: relation + trust + emotion -->
                    <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                 SuggestedHeight="52"
                                 VerticalAlignment="Top"
                                 Brush="Encyclopedia.TopBanner">
                      <Children>
                        <!-- Relation left -->
                        <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                       HorizontalAlignment="Left" VerticalAlignment="Top"
                                       PositionXOffset="10" PositionYOffset="8"
                                       Brush="SPScoreboard.Subtitle.Text"
                                       Brush.FontSize="16" Brush.Color="@RelationColor"
                                       Text="@RelationText" IsDisabled="true" />
                        <!-- Trust right -->
                        <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                       HorizontalAlignment="Right" VerticalAlignment="Top"
                                       PositionXOffset="-10" PositionYOffset="8"
                                       Brush="SPScoreboard.Subtitle.Text"
                                       Brush.FontSize="12" Brush.Color="!SubText"
                                       Text="@TrustLabel" IsDisabled="true" />
                        <!-- Emotion bottom-left -->
                        <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                       HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                       PositionXOffset="10" PositionYOffset="-8"
                                       Brush="SPScoreboard.Subtitle.Text"
                                       Brush.FontSize="11" Brush.Color="!SubText"
                                       Text="@EmotionLabel" IsDisabled="true" />
                      </Children>
                    </BrushWidget>

                  </Children>
                </BrushWidget>

                <!-- 4px gap -->
                <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="4" />

                <!-- ═══════════════════════════════════════════════════
                     CENTER  –  Header + messages + input
                ════════════════════════════════════════════════════════ -->
                <BrushWidget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                             SuggestedWidth="!Center.Width"
                             Brush="Encyclopedia.Frame">
                  <Children>

                    <!-- Title banner -->
                    <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                 SuggestedHeight="60"
                                 VerticalAlignment="Top"
                                 Brush="Encyclopedia.TopBanner">
                      <Children>
                        <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                       HorizontalAlignment="Center" VerticalAlignment="Top"
                                       PositionYOffset="8"
                                       Brush="SPScoreboard.Subtitle.Text"
                                       Brush.FontSize="22" Brush.Color="!Gold"
                                       Text="@NpcName" IsDisabled="true" />
                        <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                       HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                       PositionYOffset="-8"
                                       Brush="SPScoreboard.Subtitle.Text"
                                       Brush.FontSize="13" Brush.Color="!SubText"
                                       Text="@NpcTitle" IsDisabled="true" />
                      </Children>
                    </BrushWidget>

                    <!-- Divider below header -->
                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                            SuggestedHeight="12"
                            VerticalAlignment="Top" PositionYOffset="60"
                            Sprite="StdAssets\Popup\divider" />

                    <!-- Message scroll area -->
                    <ScrollablePanel Id="MsgScroll"
                                     WidthSizePolicy="StretchToParent"
                                     HeightSizePolicy="Fixed" SuggestedHeight="628"
                                     VerticalAlignment="Top" PositionYOffset="76"
                                     AutoHideScrollBars="true"
                                     ClipRect="MsgClip"
                                     InnerPanel="MsgClip\MsgList"
                                     VerticalScrollbar="..\MsgBar\Scrollbar">
                      <Children>
                        <Widget Id="MsgClip"
                                WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                ClipContents="true">
                          <Children>
                            <!--
                              One item per segment. No IsVisible.
                              @MessageColor  = fully-opaque dark brown for speech, transparent for rest.
                              @SenderColor   = gold for sender, cream for speech, red for emote, purple for action.
                              Empty Text/SenderName take zero height and disappear.
                            -->
                            <ListPanel Id="MsgList"
                                       DataSource="{MessageList}"
                                       WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                       StackLayout.LayoutMethod="Vertical"
                                       Margin="12,6,12,6">
                              <ItemTemplate>
                                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                        Sprite="BlankWhiteSquare_9" Color="@MessageColor"
                                        MarginBottom="2">
                                  <Children>
                                    <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                               StackLayout.LayoutMethod="Vertical">
                                      <Children>
                                        <!-- Sender name (non-empty only on sender segments) -->
                                        <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                       MarginTop="4"
                                                       Brush="SPScoreboard.Subtitle.Text"
                                                       Brush.FontSize="15" Brush.Color="@SenderColor"
                                                       Text="@SenderName"
                                                       IsDisabled="true" />
                                        <!-- Message text (speech / emote / action) -->
                                        <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                       Margin="8,4,8,4"
                                                       Brush="SPScoreboard.Subtitle.Text"
                                                       Brush.FontSize="13" Brush.Color="@SenderColor"
                                                       Text="@MessageText"
                                                       IsDisabled="true" />
                                      </Children>
                                    </ListPanel>
                                  </Children>
                                </Widget>
                              </ItemTemplate>
                            </ListPanel>
                          </Children>
                        </Widget>
                      </Children>
                    </ScrollablePanel>

                    <Standard.VerticalScrollbar Id="MsgBar"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                PositionYOffset="76"
                                                HeightSizePolicy="Fixed" SuggestedHeight="628" />

                    <!-- Divider above input -->
                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                            SuggestedHeight="12"
                            VerticalAlignment="Bottom" PositionYOffset="-48"
                            Sprite="StdAssets\Popup\divider" />

                    <!-- Input bar -->
                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                            SuggestedHeight="48"
                            VerticalAlignment="Bottom"
                            Sprite="BlankWhiteSquare_9" Color="#0A0806FF">
                      <Children>
                        <!-- Input field using vanilla name-input styling -->
                        <Widget WidthSizePolicy="Fixed" SuggestedWidth="360"
                                HeightSizePolicy="Fixed" SuggestedHeight="36"
                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                PositionXOffset="8"
                                Sprite="General\CharacterCreation\name_input_area">
                          <Children>
                            <EditableTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Margin="10,4,10,4"
                                               Brush="Review.NameInput.Text"
                                               Text="@InputText"
                                               Command.TextChanged="OnTextChanged" />
                          </Children>
                        </Widget>

                        <ButtonWidget WidthSizePolicy="Fixed" SuggestedWidth="88"
                                      HeightSizePolicy="Fixed" SuggestedHeight="36"
                                      HorizontalAlignment="Right" VerticalAlignment="Center"
                                      PositionXOffset="-8"
                                      IsEnabled="@IsSendEnabled"
                                      Brush="Popup.Done.Button"
                                      UpdateChildrenStates="true"
                                      DoNotPassEventsToChildren="true"
                                      Command.Click="ExecuteSendMessage">
                          <Children>
                            <TextWidget Text="Send"
                                        WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                        SuggestedHeight="22" VerticalAlignment="Center"
                                        MarginLeft="10" MarginRight="10"
                                        Brush="Popup.Button.Text" />
                          </Children>
                        </ButtonWidget>
                      </Children>
                    </Widget>

                  </Children>
                </BrushWidget>

                <!-- 4px gap -->
                <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="4" />

                <!-- ═══════════════════════════════════════════════════
                     RIGHT  –  Diplomacy & Relation
                     Flat single list — section headers are items
                     with grey colour; content items use @Color.
                ════════════════════════════════════════════════════════ -->
                <BrushWidget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                             SuggestedWidth="!Right.Width"
                             Brush="Encyclopedia.Frame">
                  <Children>

                    <!-- Title banner -->
                    <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                 SuggestedHeight="50"
                                 VerticalAlignment="Top"
                                 Brush="Encyclopedia.TopBanner">
                      <Children>
                        <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Brush="SPScoreboard.Subtitle.Text"
                                       Brush.FontSize="18" Brush.Color="!Gold"
                                       Text="Diplomacy &amp; Relation" IsDisabled="true" />
                      </Children>
                    </BrushWidget>

                    <!-- Divider -->
                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                            SuggestedHeight="12"
                            VerticalAlignment="Top" PositionYOffset="50"
                            Sprite="StdAssets\Popup\divider" />

                    <!-- Scrollable content -->
                    <ScrollablePanel Id="RightScroll"
                                     WidthSizePolicy="StretchToParent"
                                     HeightSizePolicy="Fixed" SuggestedHeight="646"
                                     VerticalAlignment="Top" PositionYOffset="66"
                                     AutoHideScrollBars="true"
                                     ClipRect="RightClip"
                                     InnerPanel="RightClip\RightList"
                                     VerticalScrollbar="..\RightBar\Scrollbar">
                      <Children>
                        <Widget Id="RightClip"
                                WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                ClipContents="true">
                          <Children>
                            <ListPanel Id="RightList"
                                       DataSource="{RightPanelItems}"
                                       WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                       StackLayout.LayoutMethod="Vertical"
                                       Margin="10,4,10,4">
                              <ItemTemplate>
                                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                        MarginBottom="3">
                                  <Children>
                                    <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                   Brush="SPScoreboard.Subtitle.Text"
                                                   Brush.FontSize="12" Brush.Color="@Color"
                                                   Text="@Text" IsDisabled="true" />
                                  </Children>
                                </Widget>
                              </ItemTemplate>
                            </ListPanel>
                          </Children>
                        </Widget>
                      </Children>
                    </ScrollablePanel>

                    <Standard.VerticalScrollbar Id="RightBar"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                PositionYOffset="66"
                                                HeightSizePolicy="Fixed" SuggestedHeight="646" />

                    <!-- Close button -->
                    <ButtonWidget WidthSizePolicy="Fixed" SuggestedWidth="120"
                                  HeightSizePolicy="Fixed" SuggestedHeight="38"
                                  HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                  PositionYOffset="-10"
                                  Brush="Popup.Cancel.Button"
                                  UpdateChildrenStates="true"
                                  DoNotPassEventsToChildren="true"
                                  Command.Click="ExecuteReturn">
                      <Children>
                        <TextWidget Text="Close"
                                    WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                    SuggestedHeight="22" VerticalAlignment="Center"
                                    MarginLeft="30" MarginRight="25"
                                    Brush="Popup.Button.Text" />
                      </Children>
                    </ButtonWidget>

                  </Children>
                </BrushWidget>

              </Children>
            </ListPanel>

          </Children>
        </Widget>

      </Children>
    </Widget>
  </Window>
</Prefab>
