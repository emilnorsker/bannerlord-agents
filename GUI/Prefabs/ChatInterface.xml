<Prefab>
  <!--
    Layout — left-aligned, full height:
      Left  (x=0..460)   : opaque dark backdrop (#141414).
                           Stat overlay (TopBanner) at top.
      Sep   (x=460..462) : thin separator
      Frame (x=462..end) : opaque dark backdrop (#141414) wrapping center+right.
        Center: fills frame minus right column.
        Right : fixed 300px at right edge.

    Sprites/brushes: confirmed from WorldEventsWindow.xml, AIInfluenceTextQueryPopup.xml,
    SPConversation.xml, ConversationBrush.xml, NativeSpriteData.xml.
  -->
  <Constants>
    <Constant Name="Header.H"      Value="80" />
    <Constant Name="Left.W"        Value="460" />
    <Constant Name="Right.W"       Value="300" />
    <Constant Name="Sep.W"         Value="2" />
    <Constant Name="Input.H"       Value="52" />
    <Constant Name="Bubble.W"      Value="430" />
    <Constant Name="Gold"          Value="#FFE6B685" />
    <Constant Name="SubText"       Value="#9BA4B5FF" />
    <Constant Name="SepColor"      Value="#FFFFFF22" />
    <Constant Name="Frame.Start"   Value="462" />
    <Constant Name="Frame.End"     Value="302" />
  </Constants>

  <Window Id="ChatInterfaceWindow" Layer="Overlay">

    <!-- Outer container: full screen, holds left + framed block side by side -->
    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
            DoNotAcceptEvents="false">
      <Children>

        <!-- ══ LEFT COLUMN — opaque backdrop ══ -->
        <Widget HorizontalAlignment="Left"
                WidthSizePolicy="Fixed" SuggestedWidth="!Left.W"
                HeightSizePolicy="StretchToParent"
                Sprite="BlankWhite" Color="#141414FF">
          <Children>
            <!-- Stat overlay at top of left column -->
            <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                         SuggestedHeight="52"
                         VerticalAlignment="Top"
                         Brush="Encyclopedia.TopBanner">
              <Children>
                <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                               HorizontalAlignment="Left" VerticalAlignment="Top"
                               PositionXOffset="10" PositionYOffset="8"
                               Brush="Conversation.Relation.Text"
                               Brush.FontSize="21" Color="@RelationColor"
                               Text="@RelationText" IsDisabled="true" />
                <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                               HorizontalAlignment="Right" VerticalAlignment="Top"
                               PositionXOffset="-10" PositionYOffset="8"
                               Brush="Conversation.Relation.Text"
                               Text="@TrustLabel" IsDisabled="true" />
                <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                               HorizontalAlignment="Left" VerticalAlignment="Bottom"
                               PositionXOffset="10" PositionYOffset="-8"
                               Brush="Conversation.Relation.Text"
                               Text="@EmotionLabel" IsDisabled="true" />
              </Children>
            </BrushWidget>
          </Children>
        </Widget>

        <!-- Left separator -->
        <Widget HorizontalAlignment="Left"
                WidthSizePolicy="Fixed" SuggestedWidth="!Sep.W"
                HeightSizePolicy="StretchToParent"
                PositionXOffset="!Left.W"
                Sprite="BlankWhiteSquare_9" Color="!SepColor" />

        <!-- ══ CENTER + RIGHT — custom chat_panel_bg asset ════════════════ -->
        <!-- MarginLeft=Frame.Start so the frame aligns after the left column -->
        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                MarginLeft="!Frame.Start"
                Sprite="chat_panel_bg" Color="#141414FF">
          <!-- BlankWhite sprite required: Color alone has no effect on a bare Widget in Gauntlet -->
          <Children>
            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                    DoNotAcceptEvents="false">
              <Children>

                <!-- Header: "Conversation Log" label + NPC name (Figma: Font/Body/Body2, #FFE38F) -->
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                        SuggestedHeight="!Header.H"
                        VerticalAlignment="Top"
                        Sprite="chat_panel_bg" Color="#141414FF">
                  <!-- BlankWhite sprite required: Color alone has no effect on a bare Widget in Gauntlet -->
                  <Children>
                    <!-- "Conversation Log" static label -->
                    <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                PositionXOffset="16" PositionYOffset="10"
                                Brush="Chat.Header.Label"
                                Text="Conversation Log" IsDisabled="true" />
                    <!-- NPC name -->
                    <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                   PositionXOffset="16" PositionYOffset="-28"
                                   Brush="Chat.Sender.Name"
                                   Text="@NpcName" IsDisabled="true" />
                    <!-- NPC title (e.g. Lord of X, Wanderer) -->
                    <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                PositionXOffset="16" PositionYOffset="-10"
                                Brush="SPScoreboard.Subtitle.Text"
                                Brush.FontSize="12" Text="@NpcTitle" IsDisabled="true" />
                  </Children>
                </Widget>

                <!-- ── CENTER COLUMN: fills frame minus right panel ── -->
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                        MarginTop="!Header.H" MarginRight="!Frame.End">
                  <Children>
                    <!-- Middle panel background: custom chat_panel_bg -->
                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                            Sprite="chat_panel_bg" AlphaFactor="1.0"
                            DoNotAcceptEvents="true" />

                    <!-- Message scroll area -->
                    <ScrollablePanel Id="MsgScroll"
                                     WidthSizePolicy="StretchToParent"
                                     HeightSizePolicy="StretchToParent"
                                     MarginTop="4" MarginBottom="!Input.H" MarginRight="24"
                                     AutoHideScrollBars="true"
                                     ClipRect="MsgClip"
                                     InnerPanel="MsgClip\MsgList"
                                     VerticalScrollbar="..\MsgScrollbar\Scrollbar">
                      <Children>
                        <Widget Id="MsgClip"
                                WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                ClipContents="true">
                          <Children>
                                      <ListPanel Id="MsgList"
                                       DataSource="{MessageList}"
                                       WidthSizePolicy="StretchToParent"
                                       HeightSizePolicy="CoverChildren"
                                       StackLayout.LayoutMethod="VerticalBottomToTop"
                                       Spacing="10"
                                       MarginLeft="18" MarginRight="18"
                                       MarginTop="6" MarginBottom="6">
                              <ItemTemplate>
                                <!--
                                  Messenger layout: NPC left, player right.
                                  IsVisible collapse confirmed: SPConversation.xml @IsPersuading.
                                  ContentSegments preserves speech/emote/action order.
                                -->
                                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                        MarginTop="2" MarginBottom="1">
                                  <Children>

                                    <!-- Separator line above each message group (Figma: organic gray gradient strip) -->
                                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                            SuggestedHeight="16"
                                            VerticalAlignment="Top"
                                            Sprite="chat_msg_separator"
                                            AlphaFactor="0.85"
                                            DoNotAcceptEvents="true" />

                                    <!-- NPC side: left-aligned, constrained right -->
                                    <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                               StackLayout.LayoutMethod="VerticalBottomToTop"
                                               MarginLeft="12" MarginRight="160"
                                               IsVisible="@IsNpc">
                                      <Children>
                                        <Widget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                Sprite="name_shadow_9" AlphaFactor="0.7">
                                          <Children>
                                            <ListPanel WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                       StackLayout.LayoutMethod="HorizontalLeftToRight"
                                                       MarginLeft="10" MarginTop="4" MarginBottom="4">
                                              <Children>
                                                <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                               Brush="Chat.Sender.Name"
                                                               Text="@SenderName" IsDisabled="true" />
                                                <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                            VerticalAlignment="Bottom" MarginLeft="8" MarginBottom="3"
                                                            Brush="SPScoreboard.Subtitle.Text"
                                                            Brush.FontSize="17" Brush.FontColor="@TypeTagColor"
                                                            Text="@TypeTag" />
                                              </Children>
                                            </ListPanel>
                                          </Children>
                                        </Widget>
                                        <!-- Ordered content segments -->
                                        <ListPanel DataSource="{ContentSegments}"
                                                   WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                   StackLayout.LayoutMethod="VerticalBottomToTop"
                                                   Spacing="10">
                                          <ItemTemplate>
                                            <!-- Single root required by Gauntlet ItemTemplate (fix from main).
                                                 Body/pill visibility toggled via IsVisible; sprites removed in favour of Figma brushes. -->
                                            <Widget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren">
                                              <Children>
                                                <!-- NPC body segment -->
                                                <Widget WidthSizePolicy="Fixed" SuggestedWidth="!Bubble.W" HeightSizePolicy="CoverChildren"
                                                        HorizontalAlignment="Left" IsVisible="@IsBody"
                                                        MarginTop="2" MarginBottom="2">
                                                  <Children>
                                                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                                Margin="4,2,4,2"
                                                                Brush="Chat.Body.Text"
                                                                Text="@Text" />
                                                  </Children>
                                                </Widget>
                                                <!-- NPC pill segment (action/emote — orange) -->
                                                <Widget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                        HorizontalAlignment="Left" IsVisible="@IsPill"
                                                        MarginTop="2" MarginBottom="2">
                                                  <Children>
                                                    <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                                Margin="4,2,4,2"
                                                                Brush="Chat.Action.Text"
                                                                Text="@Text" />
                                                  </Children>
                                                </Widget>
                                              </Children>
                                            </Widget>
                                          </ItemTemplate>
                                        </ListPanel>
                                      </Children>
                                    </ListPanel>

                                    <!-- Player side: right-aligned, constrained left -->
                                    <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                               StackLayout.LayoutMethod="VerticalBottomToTop"
                                               MarginLeft="160" MarginRight="12"
                                               HorizontalAlignment="Right"
                                               IsVisible="@IsPlayer">
                                      <Children>
                                        <Widget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                HorizontalAlignment="Right">
                                          <Children>
                                            <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                           HorizontalAlignment="Right"
                                                           MarginRight="10" MarginTop="4" MarginBottom="4"
                                                           Brush="Chat.Sender.Name"
                                                           Text="@SenderName" IsDisabled="true" />
                                          </Children>
                                        </Widget>
                                        <!-- Ordered content segments (right-aligned text) -->
                                        <ListPanel DataSource="{ContentSegments}"
                                                   WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                   StackLayout.LayoutMethod="VerticalBottomToTop"
                                                   Spacing="10">
                                          <ItemTemplate>
                                            <!-- Single root required by Gauntlet ItemTemplate (fix from main).
                                                 Body/pill visibility toggled via IsVisible; sprites removed in favour of Figma brushes. -->
                                            <Widget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" HorizontalAlignment="Right">
                                              <Children>
                                                <!-- Player body segment -->
                                                <Widget WidthSizePolicy="Fixed" SuggestedWidth="!Bubble.W" HeightSizePolicy="CoverChildren"
                                                        HorizontalAlignment="Right" IsVisible="@IsBody"
                                                        MarginTop="2" MarginBottom="2">
                                                  <Children>
                                                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                                Margin="4,2,4,2"
                                                                Brush="Chat.Body.Text"
                                                                TextHorizontalAlignment="Right"
                                                                Text="@Text" />
                                                  </Children>
                                                </Widget>
                                                <!-- Player pill segment (action/outcome) -->
                                                <Widget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                        HorizontalAlignment="Right" IsVisible="@IsPill"
                                                        MarginTop="2" MarginBottom="2">
                                                  <Children>
                                                    <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                                Margin="4,2,4,2"
                                                                Brush="Chat.Action.Text"
                                                                TextHorizontalAlignment="Right"
                                                                Text="@Text" />
                                                  </Children>
                                                </Widget>
                                              </Children>
                                            </Widget>
                                          </ItemTemplate>
                                        </ListPanel>
                                      </Children>
                                    </ListPanel>

                                  </Children>
                                </Widget>
                              </ItemTemplate>
                            </ListPanel>
                          </Children>
                        </Widget>
                      </Children>
                    </ScrollablePanel>

                    <Standard.VerticalScrollbar Id="MsgScrollbar"
                                                WidthSizePolicy="Fixed" SuggestedWidth="22"
                                                HeightSizePolicy="StretchToParent"
                                                HorizontalAlignment="Right"
                                                MarginTop="4" MarginBottom="!Input.H"
                                                MarginRight="2" />

                    <!-- Separator above input -->
                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                            SuggestedHeight="2"
                            VerticalAlignment="Bottom" PositionYOffset="-52"
                            Sprite="BlankWhiteSquare_9" Color="!SepColor" />

                    <!-- Input bar -->
                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                            SuggestedHeight="!Input.H"
                            VerticalAlignment="Bottom"
                            Sprite="BlankWhite" Color="#1A110CFF">
                      <Children>
                        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                Sprite="frame_9" ExtendLeft="4" ExtendTop="4" ExtendRight="4" ExtendBottom="4"
                                AlphaFactor="0.34" IsEnabled="false" />
                        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                Sprite="General\CharacterCreation\character_creation_background_gradient"
                                Color="#2A1A11FF" AlphaFactor="0.2" IsEnabled="false" />
                        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                SuggestedHeight="38"
                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                MarginLeft="8" MarginRight="106"
                                Sprite="General\CharacterCreation\name_input_area">
                          <Children>
                            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                    Sprite="frame_9" ExtendLeft="3" ExtendTop="3" ExtendRight="3" ExtendBottom="3"
                                    AlphaFactor="0.16" IsEnabled="false" />
                            <EditableTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Margin="10,4,10,4"
                                               Brush="Review.NameInput.Text"
                                               Text="@InputText"
                                               Command.TextChanged="OnTextChanged" />
                          </Children>
                        </Widget>
                        <ButtonWidget WidthSizePolicy="Fixed" SuggestedWidth="90"
                                      HeightSizePolicy="Fixed" SuggestedHeight="38"
                                      HorizontalAlignment="Right" VerticalAlignment="Center"
                                      MarginRight="8"
                                      IsEnabled="@IsSendEnabled"
                                      Brush="Popup.Done.Button"
                                      UpdateChildrenStates="true"
                                      DoNotPassEventsToChildren="true"
                                      Command.Click="ExecuteSendMessage">
                          <Children>
                            <TextWidget Text="Send"
                                        WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                        SuggestedHeight="22" VerticalAlignment="Center"
                                        MarginLeft="20" MarginRight="20"
                                        Brush="Popup.Button.Text" />
                          </Children>
                        </ButtonWidget>
                      </Children>
                    </Widget>

                  </Children>
                </Widget>

                <!-- Right separator — PositionXOffset = -Right.W (fixed: was -280, now -300) -->
                <Widget HorizontalAlignment="Right"
                        WidthSizePolicy="Fixed" SuggestedWidth="!Sep.W"
                        HeightSizePolicy="StretchToParent"
                        PositionXOffset="-300"
                        MarginTop="!Header.H"
                        Sprite="BlankWhiteSquare_9" Color="!SepColor" />

                <!-- ── RIGHT COLUMN ── -->
                <Widget HorizontalAlignment="Right"
                        WidthSizePolicy="Fixed" SuggestedWidth="!Right.W"
                        HeightSizePolicy="StretchToParent"
                        MarginTop="!Header.H">
                  <Children>
                    <!-- Right column background: custom chat_panel_bg -->
                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                            Sprite="chat_panel_bg" Color="#141414FF" DoNotAcceptEvents="true" />

                    <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                   SuggestedHeight="36"
                                   VerticalAlignment="Top" HorizontalAlignment="Center"
                                   PositionYOffset="8"
                                   Brush="SPScoreboard.Subtitle.Text"
                                   Brush.FontSize="23" Color="!Gold"
                                   Text="Diplomacy &amp; Relation" IsDisabled="true" />

                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                            SuggestedHeight="2"
                            VerticalAlignment="Top" PositionYOffset="48"
                            MarginLeft="8" MarginRight="8"
                            Sprite="BlankWhiteSquare_9" Color="!SepColor" />

                    <ScrollablePanel Id="RightScroll"
                                     WidthSizePolicy="StretchToParent"
                                     HeightSizePolicy="StretchToParent"
                                     MarginTop="54" MarginBottom="50" MarginRight="24"
                                     AutoHideScrollBars="true"
                                     ClipRect="RightClip"
                                     InnerPanel="RightClip\RightList"
                                     VerticalScrollbar="..\RightScrollbar\Scrollbar">
                      <Children>
                        <Widget Id="RightClip"
                                WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                ClipContents="true">
                          <Children>
                            <NavigatableListPanel Id="RightList"
                                                 DataSource="{RightPanelItems}"
                                                 WidthSizePolicy="StretchToParent"
                                                 HeightSizePolicy="CoverChildren"
                                                 StackLayout.LayoutMethod="VerticalTopToBottom"
                                                 Spacing="3"
                                                 MarginLeft="8" MarginRight="8"
                                                 MarginTop="4" MarginBottom="4">
                              <ItemTemplate>
                                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren">
                                  <Children>
                                    <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                   Brush="SPScoreboard.Subtitle.Text"
                                                   Brush.FontSize="17" Color="@Color"
                                                   Text="@Text" IsDisabled="true" />
                                  </Children>
                                </Widget>
                              </ItemTemplate>
                            </NavigatableListPanel>
                          </Children>
                        </Widget>
                      </Children>
                    </ScrollablePanel>

                    <Standard.VerticalScrollbar Id="RightScrollbar"
                                                WidthSizePolicy="Fixed" SuggestedWidth="22"
                                                HeightSizePolicy="StretchToParent"
                                                HorizontalAlignment="Right"
                                                MarginTop="54" MarginBottom="50"
                                                MarginRight="2" />

                    <ButtonWidget WidthSizePolicy="Fixed" SuggestedWidth="130"
                                  HeightSizePolicy="Fixed" SuggestedHeight="38"
                                  HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                  MarginBottom="8"
                                  Brush="Popup.Cancel.Button"
                                  UpdateChildrenStates="true"
                                  DoNotPassEventsToChildren="true"
                                  Command.Click="ExecuteReturn">
                      <Children>
                        <TextWidget Text="Close"
                                    WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                    SuggestedHeight="22" VerticalAlignment="Center"
                                    MarginLeft="30" MarginRight="25"
                                    Brush="Popup.Button.Text" />
                      </Children>
                    </ButtonWidget>

                  </Children>
                </Widget>

              </Children>
            </Widget>
          </Children>
        </Widget>

      </Children>
    </Widget>
  </Window>
</Prefab>
