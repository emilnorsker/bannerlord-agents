<Prefab>
  <Constants>
    <Constant Name="Panel.Left.Width"  Value="300" />
    <Constant Name="Panel.Center.Width" Value="480" />
    <Constant Name="Panel.Right.Width"  Value="280" />
    <Constant Name="Window.Height"      Value="760" />
    <Constant Name="Gold"   Value="#C6AC8DFF" />
    <Constant Name="DarkBg" Value="#0D0B09EE" />
    <Constant Name="MidBg"  Value="#1A1612EE" />
    <Constant Name="SubText" Value="#AAAAAAFF" />
  </Constants>

  <Window Id="ChatInterfaceWindow" Layer="Overlay">

    <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
            SuggestedWidth="1076" SuggestedHeight="!Window.Height"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            DoNotAcceptEvents="false">
      <Children>

        <!-- 3-column horizontal row -->
        <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                   StackLayout.LayoutMethod="Horizontal">
          <Children>

            <!-- ═══════════════════════════════════════════
                 LEFT  –  Portrait + top overlay
            ════════════════════════════════════════════════ -->
            <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                    SuggestedWidth="!Panel.Left.Width"
                    Sprite="BlankWhiteSquare_9" Color="!DarkBg">
              <Children>

                <AIInfluencePortraitWidget
                    WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                    HorizontalAlignment="Center" VerticalAlignment="Center" />

                <!-- Overlay at TOP: relation + trust + emotion stacked vertically -->
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                        SuggestedHeight="56"
                        VerticalAlignment="Top"
                        Sprite="BlankWhiteSquare_9" Color="#000000AA">
                  <Children>
                    <!-- Relation value (left) -->
                    <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                   HorizontalAlignment="Left" VerticalAlignment="Top"
                                   PositionXOffset="10" PositionYOffset="8"
                                   Brush="Recruitment.Popup.Title.Text"
                                   Brush.FontSize="18" Brush.Color="@RelationColor"
                                   Text="@RelationText" IsDisabled="true" />
                    <!-- Trust (right) -->
                    <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                   HorizontalAlignment="Right" VerticalAlignment="Top"
                                   PositionXOffset="-10" PositionYOffset="8"
                                   Brush="Recruitment.Popup.Title.Text"
                                   Brush.FontSize="13" Brush.Color="!SubText"
                                   Text="@TrustLabel" IsDisabled="true" />
                    <!-- Emotion (left, below relation) -->
                    <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                   PositionXOffset="10" PositionYOffset="-8"
                                   Brush="Recruitment.Popup.Title.Text"
                                   Brush.FontSize="12" Brush.Color="!SubText"
                                   Text="@EmotionLabel" IsDisabled="true" />
                  </Children>
                </Widget>

              </Children>
            </Widget>

            <!-- 4px spacer -->
            <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="4" />

            <!-- ═══════════════════════════════════════════
                 CENTER  –  Header + messages + input
            ════════════════════════════════════════════════ -->
            <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                    SuggestedWidth="!Panel.Center.Width"
                    Sprite="BlankWhiteSquare_9" Color="!MidBg">
              <Children>

                <!-- Header -->
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                        SuggestedHeight="60"
                        VerticalAlignment="Top"
                        Sprite="BlankWhiteSquare_9" Color="#00000055">
                  <Children>
                    <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                   HorizontalAlignment="Center" VerticalAlignment="Top"
                                   PositionYOffset="8"
                                   Brush="Recruitment.Popup.Title.Text"
                                   Brush.FontSize="22" Brush.Color="!Gold"
                                   Text="@NpcName" IsDisabled="true" />
                    <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                   PositionYOffset="-8"
                                   Brush="Recruitment.Popup.Title.Text"
                                   Brush.FontSize="13" Brush.Color="!SubText"
                                   Text="@NpcTitle" IsDisabled="true" />
                  </Children>
                </Widget>

                <!-- Message list -->
                <ScrollablePanel Id="MsgScroll"
                                 WidthSizePolicy="StretchToParent"
                                 HeightSizePolicy="Fixed" SuggestedHeight="648"
                                 VerticalAlignment="Top" PositionYOffset="64"
                                 AutoHideScrollBars="true"
                                 ClipRect="MsgClip"
                                 InnerPanel="MsgClip\MsgList"
                                 VerticalScrollbar="..\MsgBar\Scrollbar">
                  <Children>
                    <Widget Id="MsgClip"
                            WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                            ClipContents="true">
                      <Children>

                        <!--
                          One item = one segment (sender / speech / emote / action).
                          No IsVisible bindings — just @SenderColor drives text colour,
                          @MessageColor drives the background.
                          Empty strings take zero height so the inactive slot vanishes.
                        -->
                        <ListPanel Id="MsgList"
                                   DataSource="{MessageList}"
                                   WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                   StackLayout.LayoutMethod="Vertical"
                                   MarginTop="6" MarginBottom="6">
                          <ItemTemplate>
                            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                    Sprite="BlankWhiteSquare_9" Color="@MessageColor"
                                    MarginBottom="1" MarginLeft="10" MarginRight="10">
                              <Children>
                                <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                           StackLayout.LayoutMethod="Vertical">
                                  <Children>
                                    <!-- Sender name (non-empty only on sender segments) -->
                                    <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                                   Brush="Recruitment.Popup.Title.Text"
                                                   Brush.FontSize="15" Brush.Color="@SenderColor"
                                                   Text="@SenderName"
                                                   IsDisabled="true" />
                                    <!-- Message text (non-empty on speech/emote/action segments) -->
                                    <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                   Margin="6,3,6,3"
                                                   Brush="Recruitment.Popup.Title.Text"
                                                   Brush.FontSize="13" Brush.Color="@SenderColor"
                                                   Text="@MessageText"
                                                   IsDisabled="true" />
                                  </Children>
                                </ListPanel>
                              </Children>
                            </Widget>
                          </ItemTemplate>
                        </ListPanel>

                      </Children>
                    </Widget>
                  </Children>
                </ScrollablePanel>

                <Standard.VerticalScrollbar Id="MsgBar"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            PositionYOffset="64"
                                            HeightSizePolicy="Fixed" SuggestedHeight="648" />

                <!-- Input bar -->
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                        SuggestedHeight="48"
                        VerticalAlignment="Bottom"
                        Sprite="BlankWhiteSquare_9" Color="#00000077">
                  <Children>
                    <EditableTextWidget WidthSizePolicy="Fixed" SuggestedWidth="360"
                                        HeightSizePolicy="Fixed" SuggestedHeight="34"
                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                        PositionXOffset="8"
                                        Brush="Recruitment.Popup.Title.Text"
                                        Brush.FontSize="14"
                                        Text="@InputText"
                                        Command.TextChanged="OnTextChanged" />
                    <ButtonWidget WidthSizePolicy="Fixed" SuggestedWidth="88"
                                  HeightSizePolicy="Fixed" SuggestedHeight="34"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  PositionXOffset="-8"
                                  IsEnabled="@IsSendEnabled"
                                  Brush="ButtonBrush1"
                                  UpdateChildrenStates="true"
                                  DoNotPassEventsToChildren="true"
                                  Command.Click="ExecuteSendMessage">
                      <Children>
                        <TextWidget Text="Send"
                                    WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                    Brush="Popup.Button.Text" Brush.FontSize="14"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Children>
                    </ButtonWidget>
                  </Children>
                </Widget>

              </Children>
            </Widget>

            <!-- 4px spacer -->
            <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="4" />

            <!-- ═══════════════════════════════════════════
                 RIGHT  –  Diplomacy & Relation
                 Single flat ListPanel — section headers
                 are items with a grey colour, content items
                 use their own @Color.
            ════════════════════════════════════════════════ -->
            <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                    SuggestedWidth="!Panel.Right.Width"
                    Sprite="BlankWhiteSquare_9" Color="!DarkBg">
              <Children>

                <RichTextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                               HorizontalAlignment="Center" VerticalAlignment="Top"
                               PositionYOffset="12"
                               Brush="Recruitment.Popup.Title.Text"
                               Brush.FontSize="18" Brush.Color="!Gold"
                               Text="Diplomacy &amp; Relation" IsDisabled="true" />

                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                        SuggestedHeight="1" VerticalAlignment="Top"
                        PositionYOffset="40" Margin="10,0,10,0"
                        Sprite="BlankWhiteSquare_9" Color="#C6AC8D55" />

                <ScrollablePanel Id="RightScroll"
                                 WidthSizePolicy="StretchToParent"
                                 HeightSizePolicy="Fixed" SuggestedHeight="664"
                                 VerticalAlignment="Top" PositionYOffset="48"
                                 AutoHideScrollBars="true"
                                 ClipRect="RightClip"
                                 InnerPanel="RightClip\RightList"
                                 VerticalScrollbar="..\RightBar\Scrollbar">
                  <Children>
                    <Widget Id="RightClip"
                            WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                            ClipContents="true">
                      <Children>
                        <ListPanel Id="RightList"
                                   DataSource="{RightPanelItems}"
                                   WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                   StackLayout.LayoutMethod="Vertical"
                                   Margin="10,4,10,4">
                          <ItemTemplate>
                            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                    MarginBottom="4">
                              <Children>
                                <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                               Brush="Recruitment.Popup.Title.Text"
                                               Brush.FontSize="12" Brush.Color="@Color"
                                               Text="@Text" IsDisabled="true" />
                              </Children>
                            </Widget>
                          </ItemTemplate>
                        </ListPanel>
                      </Children>
                    </Widget>
                  </Children>
                </ScrollablePanel>

                <Standard.VerticalScrollbar Id="RightBar"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            PositionYOffset="48"
                                            HeightSizePolicy="Fixed" SuggestedHeight="664" />

                <ButtonWidget WidthSizePolicy="Fixed" SuggestedWidth="110"
                              HeightSizePolicy="Fixed" SuggestedHeight="34"
                              HorizontalAlignment="Center" VerticalAlignment="Bottom"
                              PositionYOffset="-8"
                              Brush="ButtonBrush1"
                              UpdateChildrenStates="true"
                              DoNotPassEventsToChildren="true"
                              Command.Click="ExecuteReturn">
                  <Children>
                    <TextWidget Text="Close"
                                WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                Brush="Popup.Button.Text" Brush.FontSize="14"
                                HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Children>
                </ButtonWidget>

              </Children>
            </Widget>

          </Children>
        </ListPanel>

      </Children>
    </Widget>
  </Window>
</Prefab>
