<Prefab>
    <Constants>
        <Constant Name="ChatWindow.Width" Value="400" />
        <Constant Name="ChatWindow.Height" Value="800" />
        <Constant Name="MessageArea.Height" Value="600" />
        <Constant Name="InputArea.Height" Value="100" />
        <Constant Name="ButtonArea.Height" Value="100" />
    </Constants>
    <Window Id="ChatInterfaceWindow" Layer="Overlay">
        <!-- Основное окно чата -->
        <Widget Id="ChatWindow" 
                WidthSizePolicy="Fixed" 
                HeightSizePolicy="Fixed" 
                SuggestedWidth="!ChatWindow.Width" 
                SuggestedHeight="!ChatWindow.Height" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Center"
                PositionXOffset="-20"
                DoNotAcceptEvents="false"
                Sprite="BlankWhiteSquare_9" 
                Color="#000000CC">
            <Children>
                <!-- Рамка основного окна -->
                <BrushWidget Id="ChatMainFrame" 
                             DoNotAcceptEvents="true" 
                             WidthSizePolicy="StretchToParent" 
                             HeightSizePolicy="StretchToParent" 
                             Brush="Encyclopedia.Frame">
                    <Children>
                        <!-- Заголовок чата -->
                        <Widget WidthSizePolicy="Fixed" 
                                HeightSizePolicy="Fixed" 
                                SuggestedWidth="360" 
                                SuggestedHeight="50" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Top" 
                                PositionYOffset="10" 
                                Sprite="StdAssets\tabbar_popup" 
                                IsDisabled="true">
                            <Children>
                                <RichTextWidget WidthSizePolicy="CoverChildren" 
                                               HeightSizePolicy="CoverChildren" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" 
                                               Brush="Recruitment.Popup.Title.Text" 
                                               Brush.FontSize="24" 
                                               IsDisabled="true" 
                                               Text="AI Chat" />
                            </Children>
                        </Widget>

                        <!-- Область сообщений -->
                        <ScrollablePanel Id="MessagesScrollPanel"
                                        WidthSizePolicy="CoverChildren" 
                                        HeightSizePolicy="Fixed" 
                                        SuggestedWidth="360" 
                                        SuggestedHeight="!MessageArea.Height"
                                        HorizontalAlignment="Center" 
                                        VerticalAlignment="Center" 
                                        PositionYOffset="-50"
                                        AutoHideScrollBars="true" 
                                        ClipRect="MessagesClipRect" 
                                        InnerPanel="MessagesClipRect\MessagesList" 
                                        VerticalScrollbar="..\MessagesScrollbar\Scrollbar">
                            <Children>
                                <Widget Id="MessagesClipRect" 
                                        WidthSizePolicy="CoverChildren" 
                                        HeightSizePolicy="StretchToParent" 
                                        ClipContents="true">
                                    <Children>
                                        <NavigatableListPanel Id="MessagesList" 
                                                             DataSource="{MessageList}" 
                                                             WidthSizePolicy="CoverChildren" 
                                                             HeightSizePolicy="CoverChildren" 
                                                             StackLayout.LayoutMethod="VerticalBottomToTop">
                                            <ItemTemplate>
                                                <Widget WidthSizePolicy="CoverChildren" 
                                                        HeightSizePolicy="CoverChildren" 
                                                        MarginBottom="10">
                                                    <Children>
                                                        <!-- Фон сообщения -->
                                                        <Widget WidthSizePolicy="StretchToParent" 
                                                                HeightSizePolicy="CoverChildren" 
                                                                Sprite="BlankWhiteSquare_9" 
                                                                Color="@MessageColor" />
                                                        
                                                        <!-- Имя отправителя -->
                                                        <RichTextWidget WidthSizePolicy="CoverChildren" 
                                                                       HeightSizePolicy="CoverChildren" 
                                                                       HorizontalAlignment="Left" 
                                                                       VerticalAlignment="Top" 
                                                                       PositionXOffset="10" 
                                                                       PositionYOffset="5" 
                                                                       Brush="Recruitment.Popup.Title.Text" 
                                                                       Brush.FontSize="14" 
                                                                       Brush.Color="@SenderColor"
                                                                       IsDisabled="true" 
                                                                       Text="@SenderName" />
                                                        
                                                        <!-- Текст сообщения -->
                                                        <RichTextWidget WidthSizePolicy="CoverChildren" 
                                                                       HeightSizePolicy="CoverChildren" 
                                                                       HorizontalAlignment="Left" 
                                                                       VerticalAlignment="Top" 
                                                                       PositionXOffset="10" 
                                                                       PositionYOffset="25" 
                                                                       Brush="Recruitment.Popup.Title.Text" 
                                                                       Brush.FontSize="12" 
                                                                       IsDisabled="true" 
                                                                       Text="@MessageText" />
                                                    </Children>
                                                </Widget>
                                            </ItemTemplate>
                                        </NavigatableListPanel>
                                    </Children>
                                </Widget>
                            </Children>
                        </ScrollablePanel>
                        
                        <!-- Скроллбар для сообщений -->
                        <Standard.VerticalScrollbar Id="MessagesScrollbar" 
                                                   HeightSizePolicy="CoverChildren" 
                                                   HorizontalAlignment="Right" 
                                                   MarginLeft="2" 
                                                   MarginRight="2" />

                        <!-- Область ввода -->
                        <Widget Id="InputArea"
                                WidthSizePolicy="Fixed" 
                                HeightSizePolicy="Fixed" 
                                SuggestedWidth="360" 
                                SuggestedHeight="60"
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Bottom"
                                PositionYOffset="-100"
                                Sprite="BlankWhiteSquare_9" 
                                Color="#10000000">
                            <Children>
                                <!-- Поле ввода текста -->
                                <EditableTextWidget Id="MessageInput"
                                                   WidthSizePolicy="Fixed" 
                                                   HeightSizePolicy="Fixed" 
                                                   SuggestedWidth="280" 
                                                   SuggestedHeight="40"
                                                   HorizontalAlignment="Left" 
                                                   VerticalAlignment="Center" 
                                                   PositionXOffset="10"
                                                   Brush="Recruitment.Popup.Title.Text" 
                                                   Brush.FontSize="14" 
                                                   Text="@InputText"
                                                   Command.TextChanged="OnTextChanged" />
                                
                                <!-- Кнопка "Сказать" -->
                                <ButtonWidget Id="SendButton"
                                             WidthSizePolicy="Fixed"
                                             HeightSizePolicy="Fixed"
                                             SuggestedWidth="60"
                                             SuggestedHeight="40"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Center"
                                             PositionXOffset="-10"
                                             DoNotPassEventsToChildren="true"
                                             Command.Click="ExecuteSendMessage"
                                             Brush="ButtonBrush1"
                                             UpdateChildrenStates="true">
                                    <Children>
                                        <TextWidget Text="Сказать" 
                                                   WidthSizePolicy="StretchToParent" 
                                                   HeightSizePolicy="StretchToParent" 
                                                   Brush="Popup.Button.Text"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Brush.FontSize="12" />
                                    </Children>
                                </ButtonWidget>
                            </Children>
                        </Widget>

                        <!-- Область кнопок -->
                        <Widget Id="ButtonArea"
                                WidthSizePolicy="Fixed" 
                                HeightSizePolicy="Fixed" 
                                SuggestedWidth="360" 
                                SuggestedHeight="60"
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Bottom"
                                PositionYOffset="-30">
                            <Children>
                                <!-- Кнопка "Вернуться" -->
                                <ButtonWidget Id="ReturnButton"
                                             WidthSizePolicy="Fixed"
                                             HeightSizePolicy="Fixed"
                                             SuggestedWidth="120"
                                             SuggestedHeight="40"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             DoNotPassEventsToChildren="true"
                                             Command.Click="ExecuteReturn"
                                             Brush="ButtonBrush1"
                                             Brush.Color="#CC0000"
                                             UpdateChildrenStates="true">
                                    <Children>
                                        <TextWidget Text="Вернуться" 
                                                   WidthSizePolicy="StretchToParent" 
                                                   HeightSizePolicy="StretchToParent" 
                                                   Brush="Popup.Button.Text"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Brush.FontSize="16" />
                                    </Children>
                                </ButtonWidget>
                            </Children>
                        </Widget>
                    </Children>
                </BrushWidget>
            </Children>
        </Widget>
    </Window>
</Prefab>
